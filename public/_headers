/*
  # Security headers (áp dụng cho mọi trang)
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Cache HTML ngắn (để Google crawl bản mới)
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Cache assets dài (fingerprinted bởi Astro)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Ảnh OG (generate mỗi lần build, URL không fingerprint → cache 1 ngày)
/og/*
  Cache-Control: public, max-age=86400

# Không cache sitemap/robots (Google cần bản mới nhất)
/sitemap*.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600

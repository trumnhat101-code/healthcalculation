---
/**
 * AdSlot.astro — placeholder AdSense unit
 * Placeholder ẩn cho đến khi được AdSense approve.
 * Khi approve: uncomment <ins> block bên dưới, xoá dòng comment trên.
 */
export interface Props {
  slot?: string;
  format?: 'auto' | 'rectangle' | 'horizontal';
  label?: string;
}
const { slot = 'SLOT_ID', format = 'auto', label = 'Advertisement' } = Astro.props;
---

<!-- AdSlot: {label} — hidden until AdSense approval -->
<!--
<ins class="adsbygoogle"
  style="display:block"
  data-ad-client="ca-pub-XXXX"
  data-ad-slot={slot}
  data-ad-format={format}
  data-full-width-responsive="true"></ins>
<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
-->

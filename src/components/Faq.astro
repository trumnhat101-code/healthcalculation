---
/**
 * Faq.astro — accordion FAQ + tự sinh JSON-LD FAQPage schema
 * NOTE: schema đã được xử lý trong ToolLayout qua prop schemaFaq.
 *       Component này chỉ render HTML accordion.
 * Props:
 *   items — mảng { q, a } (cùng data dùng cho schemaFaq)
 */
export interface FaqItem { q: string; a: string; }
export interface Props { items: FaqItem[]; }
const { items } = Astro.props;
---

<section class="faq-section">
  <h2>Frequently Asked Questions</h2>
  <dl class="faq-list">
    {items.map(({ q, a }, i) => (
      <div class="faq-item">
        <dt>
          <button
            class="faq-btn"
            aria-expanded="false"
            aria-controls={`faq-ans-${i}`}
            id={`faq-q-${i}`}
          >
            {q}
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
        </dt>
        <dd id={`faq-ans-${i}`} class="faq-ans" role="region" aria-labelledby={`faq-q-${i}`} hidden>
          <p>{a}</p>
        </dd>
      </div>
    ))}
  </dl>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const ans = document.getElementById(btn.getAttribute('aria-controls')!);
      if (ans) ans.hidden = expanded;
      const icon = btn.querySelector('.faq-icon');
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .faq-section { margin-top: 36px; }
  .faq-section h2 { margin-bottom: 14px; }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
  }
  .faq-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 15px 18px;
    font-size: 15px;
    font-weight: 600;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    color: #1f2937;
  }
  .faq-btn:hover { background: #f9fafb; }
  .faq-icon {
    font-size: 20px;
    color: #16a34a;
    flex-shrink: 0;
    line-height: 1;
    font-weight: 400;
  }
  .faq-ans {
    padding: 0 18px 15px;
    font-size: 14px;
    color: #374151;
    line-height: 1.7;
    margin: 0;
  }
  .faq-ans p { margin: 0; }
</style>

---
/**
 * ToolLayout.astro — layout dùng chung cho mọi tool page
 */
export interface Props {
  title: string;
  description: string;
  canonical: string;
  schemaApp?: Record<string, unknown>;
  schemaFaq?: Array<{ q: string; a: string }>;
  color?: string;
}

const { title, description, canonical, schemaApp, schemaFaq } = Astro.props;

const faqSchema = schemaFaq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: schemaFaq.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    }
  : null;

const nav = [
  { href: '/calorie-tdee-calculator', label: 'Calorie' },
  { href: '/bmi-calculator',          label: 'BMI' },
  { href: '/macro-calculator',        label: 'Macro' },
  { href: '/sleep-calculator',        label: 'Sleep' },
  { href: '/about',                   label: 'About' },
];

const iconMap: Record<string, string> = {
  '/calorie-tdee-calculator': '🔥',
  '/bmi-calculator':          '⚖️',
  '/macro-calculator':        '🥗',
  '/sleep-calculator':        '🌙',
  '/about':                   'ℹ️',
  '/privacy':                 '🔒',
  '/disclaimer':              '⚕️',
};

const currentPath = new URL(canonical).pathname;
const isHome      = currentPath === '/';
const pageIcon    = iconMap[currentPath] ?? '⚕️';
const heroTitle   = title.split(' —')[0];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:type"        content="website" />

  <!-- JSON-LD schemas -->
  {schemaApp  && <script type="application/ld+json" set:html={JSON.stringify(schemaApp)} />}
  {faqSchema  && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- AdSense — uncomment when approved
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXX" crossorigin="anonymous"></script>
  -->

  <style>
    /* ── Tokens ── */
    :root {
      --ac:      #16a34a;
      --ac-dark: #15803d;
      --bg:      #f6faf7;
      --card:    #ffffff;
      --bd:      #e5e7eb;
      --tx:      #1f2937;
      --mut:     #6b7280;
      --radius:  14px;
      --shadow:  0 1px 3px rgba(0,0,0,.06), 0 4px 20px rgba(0,0,0,.05);
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
      color: var(--tx);
      background: var(--bg);
      line-height: 1.65;
      font-size: 16px;
    }
    a   { color: var(--ac); }
    img { max-width: 100%; height: auto; }

    /* ── Wrap ── */
    .wrap { max-width: 1140px; margin: 0 auto; padding: 0 20px; }

    /* ── Header ── */
    .site-header {
      background: #fff;
      border-bottom: 1px solid var(--bd);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 1px 0 var(--bd);
    }
    .hdr-inner {
      display: flex;
      align-items: center;
      height: 58px;
      gap: 10px;
    }
    .logo {
      font-weight: 800;
      color: var(--ac);
      font-size: 16px;
      text-decoration: none;
      letter-spacing: -.3px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 7px;
    }
    .logo-mark {
      width: 28px; height: 28px;
      background: var(--ac);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 900; color: #fff;
    }
    .site-nav {
      display: flex;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      flex: 1;
      justify-content: flex-end;
    }
    .site-nav::-webkit-scrollbar { display: none; }
    .site-nav a {
      color: var(--mut);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      padding: 6px 10px;
      border-radius: 7px;
      transition: background .15s, color .15s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .site-nav a:hover             { background: #f0fdf4; color: var(--ac); }
    .site-nav a[aria-current="page"] {
      background: #f0fdf4;
      color: var(--ac);
      font-weight: 700;
    }

    /* ── Page Hero Strip ── */
    .page-hero {
      background: linear-gradient(135deg, #16a34a 0%, #0891b2 100%);
      padding: 16px 0;
    }
    .ph-inner {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .ph-icon   { font-size: 26px; line-height: 1; flex-shrink: 0; }
    .ph-eyebrow {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: rgba(255,255,255,.72);
      margin-bottom: 3px;
    }
    .ph-title {
      font-size: 17px;
      font-weight: 800;
      color: #fff;
      line-height: 1.2;
    }

    /* ── Page Layout (2-col grid) ── */
    .page-layout {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 28px;
      padding: 28px 0 52px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .page-layout { grid-template-columns: 1fr; }
      .sidebar { order: 3; }
    }

    /* ── Typography ── */
    h1 { font-size: 27px; font-weight: 800; margin-bottom: 6px; line-height: 1.25; }
    h2 { font-size: 19px; font-weight: 700; margin: 28px 0 10px; }
    h3 { font-size: 16px; font-weight: 700; margin: 18px 0 6px; }
    p  { margin-bottom: 12px; }
    .lead { color: var(--mut); font-size: 15px; margin-bottom: 20px; max-width: 680px; }

    /* ── Card ── */
    .card {
      background: var(--card);
      border: 1px solid var(--bd);
      border-radius: var(--radius);
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
    }

    /* ── Breadcrumb ── */
    .breadcrumb {
      font-size: 12px;
      color: var(--mut);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 5px;
      flex-wrap: wrap;
    }
    .breadcrumb a { color: var(--mut); text-decoration: none; }
    .breadcrumb a:hover { color: var(--ac); text-decoration: underline; }
    .breadcrumb span { opacity: .5; }

    /* ── Footer ── */
    .site-footer {
      background: #fff;
      border-top: 1px solid var(--bd);
      padding: 24px 0;
    }
    .ftr-inner {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--mut);
    }
    .ftr-brand { font-weight: 700; color: var(--tx); }
    .ftr-links { display: flex; gap: 16px; flex-wrap: wrap; }
    .ftr-links a { color: var(--mut); text-decoration: none; }
    .ftr-links a:hover { color: var(--ac); }

  </style>
</head>
<body>

<header class="site-header">
  <div class="wrap hdr-inner">
    <a class="logo" href="/">
      <span class="logo-mark" aria-hidden="true">H</span>
      HealthCalculation
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      {nav.map(({ href, label }) => (
        <a href={href} aria-current={currentPath === href ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
  </div>
</header>

{!isHome && (
  <div class="page-hero" aria-hidden="true">
    <div class="wrap">
      <div class="ph-inner">
        <span class="ph-icon">{pageIcon}</span>
        <div>
          <p class="ph-eyebrow">Free Calculator</p>
          <p class="ph-title">{heroTitle}</p>
        </div>
      </div>
    </div>
  </div>
)}

<main>
  <div class="wrap">
    <slot />
  </div>
</main>

<footer class="site-footer">
  <div class="wrap ftr-inner">
    <div>
      <p class="ftr-brand">HealthCalculation.com</p>
      <p>&copy; {new Date().getFullYear()} HealthCalculation.com &mdash; For informational purposes only. Not medical advice.</p>
    </div>
    <nav class="ftr-links" aria-label="Footer navigation">
      <a href="/about">About</a>
      <a href="/privacy">Privacy</a>
      <a href="/disclaimer">Disclaimer</a>
    </nav>
  </div>
</footer>

</body>
</html>

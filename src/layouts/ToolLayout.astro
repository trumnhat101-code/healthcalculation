---
/**
 * ToolLayout.astro — layout dùng chung cho mọi tool page
 */
export interface Props {
  title: string;
  description: string;
  canonical: string;
  schemaApp?: Record<string, unknown>;
  schemaFaq?: Array<{ q: string; a: string }>;
  color?: string;
  pageIcon?: string;
  heroTitle?: string;
}

const { title, description, canonical, schemaApp, schemaFaq,
        pageIcon: pagePropIcon, heroTitle: pagePropHeroTitle } = Astro.props;

const faqSchema = schemaFaq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: schemaFaq.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    }
  : null;

const nav = [
  { href: '/calorie-tdee-calculator',  label: 'Calorie' },
  { href: '/bmi-calculator',           label: 'BMI' },
  { href: '/macro-calculator',         label: 'Macro' },
  { href: '/ideal-weight-calculator',  label: 'Ideal Weight' },
  { href: '/body-fat-calculator',      label: 'Body Fat' },
  { href: '/sleep-calculator',         label: 'Sleep' },
  { href: '/protein-calculator',         label: 'Protein' },
  { href: '/water-intake-calculator',   label: 'Water Intake' },
  { href: '/heart-rate-zone-calculator', label: 'Heart Rate' },
  { href: '/calories-burned-calculator', label: 'Calories Burned' },
  { href: '/guides',                    label: 'Guides' },
  { href: '/about',                    label: 'About' },
];

const iconMap: Record<string, string> = {
  '/ideal-weight-calculator': '&#9878;',
  '/body-fat-calculator':     '&#37;',
  '/calorie-tdee-calculator': '🔥',
  '/bmi-calculator':          '⚖️',
  '/macro-calculator':        '🥗',
  '/sleep-calculator':        '🌙',
  '/protein-calculator':         '&#129372;',
  '/water-intake-calculator':   '&#128167;',
  '/heart-rate-zone-calculator': '&#128147;',
  '/calories-burned-calculator': '&#128293;',
  '/about':                   'ℹ️',
  '/privacy':                 '🔒',
  '/disclaimer':              '⚕️',
};

const currentPath = new URL(canonical).pathname;
const isHome      = currentPath === '/';
const pageIcon    = pagePropIcon ?? iconMap[currentPath] ?? '⚕️';
const heroTitle   = pagePropHeroTitle ?? title.split(' —')[0];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://healthcalculation.com/' },
    { '@type': 'ListItem', position: 2, name: heroTitle, item: canonical },
  ],
};
const ogImage = 'https://healthcalculation.com/og-default.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:type"        content="website" />
  <meta property="og:image"       content={ogImage} />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"      content={ogImage} />

  <!-- JSON-LD schemas -->
  {schemaApp        && <script type="application/ld+json" set:html={JSON.stringify(schemaApp)} />}
  {faqSchema        && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {!isHome          && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

  <!-- AdSense — uncomment when approved
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXX" crossorigin="anonymous"></script>
  -->

  <!-- Cloudflare Web Analytics — replace TOKEN with your beacon token from dash.cloudflare.com > Analytics > Web Analytics -->
  <!-- <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "REPLACE_WITH_CF_ANALYTICS_TOKEN"}'></script> -->

  <style is:inline>
    /* ── Tokens ── */
    :root {
      --ac:      #16a34a;
      --ac-dark: #15803d;
      --bg:      #f6faf7;
      --card:    #ffffff;
      --bd:      #e5e7eb;
      --tx:      #1f2937;
      --mut:     #6b7280;
      --radius:  14px;
      --shadow:  0 1px 3px rgba(0,0,0,.06), 0 4px 20px rgba(0,0,0,.05);
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
      color: var(--tx);
      background: var(--bg);
      line-height: 1.65;
      font-size: 16px;
    }
    a   { color: var(--ac); }
    img { max-width: 100%; height: auto; }

    /* ── Wrap ── */
    .wrap { max-width: 1140px; margin: 0 auto; padding: 0 20px; }

    /* ── Header ── */
    .site-header {
      background: #fff;
      border-bottom: 1px solid var(--bd);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 1px 0 var(--bd);
    }
    .hdr-inner {
      display: flex;
      align-items: center;
      height: 58px;
      gap: 10px;
    }
    .logo {
      font-weight: 800;
      color: var(--ac);
      font-size: 16px;
      text-decoration: none;
      letter-spacing: -.3px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 7px;
    }
    .logo-mark {
      width: 28px; height: 28px;
      background: var(--ac);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 900; color: #fff;
    }
    .site-nav {
      display: flex;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      flex: 1;
      justify-content: flex-end;
    }
    .site-nav::-webkit-scrollbar { display: none; }
    .site-nav a {
      color: var(--mut);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      padding: 6px 10px;
      border-radius: 7px;
      transition: background .15s, color .15s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .site-nav a:hover             { background: #f0fdf4; color: var(--ac); }
    .site-nav a[aria-current="page"] {
      background: #f0fdf4;
      color: var(--ac);
      font-weight: 700;
    }
    /* ── Mobile header: 2-row layout ── */
    @media (max-width: 640px) {
      .hdr-inner {
        height: auto;
        flex-direction: column;
        align-items: flex-start;
        padding-top: 10px;
        gap: 0;
      }
      .logo {
        padding-bottom: 8px;
        padding-left: 0;
      }
      .site-nav {
        width: calc(100% + 40px);
        margin-left: -20px;
        justify-content: flex-start;
        border-top: 1px solid var(--bd);
        padding: 6px 20px 8px;
      }
      .site-nav a {
        font-size: 13px;
        padding: 5px 10px;
      }
      /* iOS: prevent auto-zoom on input focus */
      input[type="number"], input[type="text"], select {
        font-size: 16px !important;
      }
    }

    /* ── Page Hero Strip ── */
    .page-hero {
      background: linear-gradient(135deg, #16a34a 0%, #0891b2 100%);
      padding: 16px 0;
    }
    .ph-inner {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .ph-icon   { font-size: 26px; line-height: 1; flex-shrink: 0; }
    .ph-eyebrow {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: rgba(255,255,255,.72);
      margin-bottom: 3px;
    }
    .ph-title {
      font-size: 17px;
      font-weight: 800;
      color: #fff;
      line-height: 1.2;
    }

    /* ── Page Layout (2-col grid) ── */
    .page-layout {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 28px;
      padding: 28px 0 52px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .page-layout { grid-template-columns: 1fr; }
      .sidebar { order: 3; }
    }

    /* ── Typography ── */
    h1 { font-size: 27px; font-weight: 800; margin-bottom: 6px; line-height: 1.25; }
    h2 { font-size: 19px; font-weight: 700; margin: 28px 0 10px; }
    h3 { font-size: 16px; font-weight: 700; margin: 18px 0 6px; }
    p  { margin-bottom: 12px; }
    .lead { color: var(--mut); font-size: 15px; margin-bottom: 20px; max-width: 680px; }

    /* ── Card ── */
    .card {
      background: var(--card);
      border: 1px solid var(--bd);
      border-radius: var(--radius);
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
    }

    /* ── Breadcrumb ── */
    .breadcrumb {
      font-size: 12px;
      color: var(--mut);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 5px;
      flex-wrap: wrap;
    }
    .breadcrumb a { color: var(--mut); text-decoration: none; }
    .breadcrumb a:hover { color: var(--ac); text-decoration: underline; }
    .breadcrumb span { opacity: .5; }

    /* ── Footer ── */
    .site-footer {
      background: #fff;
      border-top: 1px solid var(--bd);
      padding: 24px 0;
    }
    .ftr-inner {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--mut);
    }
    .ftr-brand { font-weight: 700; color: var(--tx); }
    .ftr-links { display: flex; gap: 16px; flex-wrap: wrap; }
    .ftr-links a { color: var(--mut); text-decoration: none; }
    .ftr-links a:hover { color: var(--ac); }


    /* ══════════════════════════════════════════════════
       Shared Form Styles — apply to all tool pages
       ══════════════════════════════════════════════════ */

    /* Grids */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
    @media (max-width: 560px) { .grid-2 { grid-template-columns: 1fr; } }
    @media (max-width: 560px) { .grid-3 { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 520px) { .grid-3 { grid-template-columns: 1fr; } }

    /* Field */
    .field-group { position: relative; }
    .field-label {
      display: block; font-size: 12px; font-weight: 700;
      color: var(--mut); margin-bottom: 5px;
      text-transform: uppercase; letter-spacing: .4px;
    }
    input[type="number"],
    input[type="text"],
    input[type="time"],
    select {
      width: 100%;
      padding: 10px 12px;
      border: 1.5px solid var(--bd);
      border-radius: 9px;
      font-size: 15px;
      outline: none;
      background: #fff;
      color: var(--tx);
      transition: border-color .15s;
      -webkit-appearance: none;
      appearance: none;
    }
    input[type="number"]:focus,
    input[type="text"]:focus,
    input[type="time"]:focus,
    select:focus { border-color: var(--ac); box-shadow: 0 0 0 3px rgba(22,163,74,.1); }

    /* Prevent iOS Safari auto-zoom (requires font-size >= 16px) */
    @media (max-width: 768px) {
      input[type="number"],
      input[type="text"],
      input[type="time"],
      select { font-size: 16px !important; }
    }

    /* Unit label + prevent text overlap */
    .field-unit { position: absolute; right: 12px; bottom: 11px; font-size: 12px; color: #9ca3af; pointer-events: none; }
    .field-group:has(.field-unit) input { padding-right: 40px; }

    /* ft/in row */
    .ft-in { display: flex; align-items: center; gap: 6px; }
    .ft-in input { flex: 1; padding-right: 12px !important; }
    .field-sep { font-size: 13px; color: #9ca3af; flex-shrink: 0; }

    /* Segmented controls */
    .seg-group { display: flex; gap: 8px; flex-wrap: wrap; }
    .seg-opt { flex: 1; min-width: 120px; }
    .seg-opt input { display: none; }
    .seg-opt span {
      display: block; text-align: center;
      padding: 8px 12px; border: 1.5px solid var(--bd);
      border-radius: 8px; font-size: 14px; cursor: pointer;
      color: #374151; transition: all .15s; user-select: none;
    }
    .seg-opt input:checked + span {
      border-color: var(--ac); color: var(--ac);
      background: #f0fdf4; font-weight: 700;
    }

    /* Submit button */
    .btn-calc {
      width: 100%; margin-top: 18px; padding: 13px;
      background: var(--ac); color: #fff;
      font-size: 16px; font-weight: 700;
      border: none; border-radius: 10px;
      cursor: pointer; transition: background .15s;
      touch-action: manipulation;
    }
    .btn-calc:hover { background: var(--ac-dark); }


    /* ── Content sections ── */
    .content-section { margin-top: 44px; }
    .content-section h2 { font-size: 20px; font-weight: 800; color: var(--tx); margin-bottom: 14px; }
    .content-section p { font-size: 15px; line-height: 1.75; color: #374151; margin-bottom: 10px; }

    /* How-it-works formula box */
    .formula-box {
      background: #f8fafc; border: 1px solid var(--bd);
      border-radius: 10px; padding: 14px 16px; margin: 10px 0;
      font-family: ui-monospace, monospace; font-size: 13px;
      color: #374151; line-height: 1.6;
    }

    /* FAQ accordion */
    .faq-list { display: flex; flex-direction: column; gap: 8px; }
    .faq-item { border: 1px solid var(--bd); border-radius: 10px; overflow: hidden; }
    .faq-item summary {
      padding: 14px 16px; font-size: 15px; font-weight: 600;
      cursor: pointer; list-style: none;
      display: flex; justify-content: space-between; align-items: center;
      gap: 10px;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; font-size: 20px; color: var(--ac); flex-shrink: 0; line-height: 1; }
    .faq-item[open] summary::after { content: '-'; }
    .faq-item[open] summary { color: var(--ac); }
    .faq-body { padding: 0 16px 14px; font-size: 14px; line-height: 1.75; color: #4b5563; }


    /* Guide CTA box */
    .guide-cta-box {
      display: flex; align-items: flex-start; gap: 16px;
      background: #f0fdf4; border: 1.5px solid #86efac;
      border-radius: 12px; padding: 18px 20px;
    }
    .gcta-icon { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
    .gcta-body { flex: 1; }
    .gcta-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #16a34a; margin-bottom: 4px; }
    .gcta-title { font-size: 15px; font-weight: 700; color: #1f2937; text-decoration: none; display: block; margin-bottom: 6px; }
    .gcta-title:hover { color: #16a34a; }
    .gcta-desc { font-size: 13px; color: #6b7280; line-height: 1.55; margin: 0; }
    .gcta-btn {
      flex-shrink: 0; align-self: center;
      background: #16a34a; color: #fff; text-decoration: none;
      font-size: 13px; font-weight: 600; padding: 9px 16px;
      border-radius: 8px; white-space: nowrap; transition: background .15s;
    }
    .gcta-btn:hover { background: #15803d; }
    @media (max-width: 540px) {
      .guide-cta-box { flex-wrap: wrap; }
      .gcta-btn { width: 100%; text-align: center; }
    }

    /* Related tools */
    .related-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 12px; }
    .related-link {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 14px; border: 1.5px solid var(--bd);
      border-radius: 8px; font-size: 13px; font-weight: 600;
      color: var(--ac); text-decoration: none; transition: all .15s;
      white-space: nowrap;
    }
    .related-link:hover { border-color: var(--ac); background: #f0fdf4; }

    /* Results table */
    .result-table { width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 14px; }
    .result-table th { background: #f0fdf4; color: var(--ac); font-weight: 700; padding: 10px 12px; text-align: left; border-bottom: 2px solid var(--bd); }
    .result-table td { padding: 9px 12px; border-bottom: 1px solid var(--bd); color: #374151; }
    .result-table tr:last-child td { border-bottom: none; }
    .result-table tr.highlight td { font-weight: 700; color: var(--ac); background: #f0fdf4; }

    
    /* ── Content sections ── */
    .content-section { margin-top: 44px; }
    .content-section h2 { font-size: 20px; font-weight: 800; color: var(--tx); margin-bottom: 14px; }
    .content-section p { font-size: 15px; line-height: 1.75; color: #374151; margin-bottom: 10px; }

    /* How-it-works formula box */
    .formula-box {
      background: #f8fafc; border: 1px solid var(--bd);
      border-radius: 10px; padding: 14px 16px; margin: 10px 0;
      font-family: ui-monospace, monospace; font-size: 13px;
      color: #374151; line-height: 1.6;
    }

    /* FAQ accordion */
    .faq-list { display: flex; flex-direction: column; gap: 8px; }
    .faq-item { border: 1px solid var(--bd); border-radius: 10px; overflow: hidden; }
    .faq-item summary {
      padding: 14px 16px; font-size: 15px; font-weight: 600;
      cursor: pointer; list-style: none;
      display: flex; justify-content: space-between; align-items: center;
      gap: 10px;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; font-size: 20px; color: var(--ac); flex-shrink: 0; line-height: 1; }
    .faq-item[open] summary::after { content: '-'; }
    .faq-item[open] summary { color: var(--ac); }
    .faq-body { padding: 0 16px 14px; font-size: 14px; line-height: 1.75; color: #4b5563; }

    /* Related tools */
    .related-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 12px; }
    .related-link {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 14px; border: 1.5px solid var(--bd);
      border-radius: 8px; font-size: 13px; font-weight: 600;
      color: var(--ac); text-decoration: none; transition: all .15s;
      white-space: nowrap;
    }
    .related-link:hover { border-color: var(--ac); background: #f0fdf4; }

    /* Results table */
    .result-table { width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 14px; }
    .result-table th { background: #f0fdf4; color: var(--ac); font-weight: 700; padding: 10px 12px; text-align: left; border-bottom: 2px solid var(--bd); }
    .result-table td { padding: 9px 12px; border-bottom: 1px solid var(--bd); color: #374151; }
    .result-table tr:last-child td { border-bottom: none; }
    .result-table tr.highlight td { font-weight: 700; color: var(--ac); background: #f0fdf4; }

    </style>
</head>
<body>

<header class="site-header">
  <div class="wrap hdr-inner">
    <a class="logo" href="/">
      <span class="logo-mark" aria-hidden="true">H</span>
      HealthCalculation
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      {nav.map(({ href, label }) => (
        <a href={href} aria-current={currentPath === href ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
  </div>
</header>

{!isHome && (
  <div class="page-hero" aria-hidden="true">
    <div class="wrap">
      <div class="ph-inner">
        <span class="ph-icon" set:html={pageIcon} />
        <div>
          <p class="ph-eyebrow">Free Calculator</p>
          <p class="ph-title">{heroTitle}</p>
        </div>
      </div>
    </div>
  </div>
)}

<main>
  <div class="wrap">
    <slot />
  </div>
</main>

<footer class="site-footer">
  <div class="wrap ftr-inner">
    <div>
      <p class="ftr-brand">HealthCalculation.com</p>
      <p>&copy; {new Date().getFullYear()} HealthCalculation.com &mdash; For informational purposes only. Not medical advice.</p>
    </div>
    <nav class="ftr-links" aria-label="Footer">
      <a href="/about">About</a>
      <a hre
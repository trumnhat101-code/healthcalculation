---
const SITE = 'https://healthcalculation.com';

const tools = [
  {
    href: '/calorie-deficit-calculator',
    title: 'Calorie Deficit Calculator',
    desc: 'Find your daily calorie target to lose 0.5, 1, or 2 pounds per week. Enter your goal weight to see a time estimate.',
    icon: '&#9986;',
    kw: 'Weight loss · TDEE-based',
  },
  {
    href: '/bmr-calculator',
    title: 'BMR Calculator',
    desc: 'Calculate your Basal Metabolic Rate using Mifflin-St Jeor and Harris-Benedict. See your TDEE at every activity level.',
    icon: '&#128200;',
    kw: 'Mifflin-St Jeor · Harris-Benedict',
  },
  {
    href: '/calorie-tdee-calculator',
    title: 'Calorie & TDEE Calculator',
    desc: 'Find your Total Daily Energy Expenditure using the Mifflin-St Jeor formula.',
    icon: '&#128293;',
    kw: 'Most popular',
  },
  {
    href: '/bmi-calculator',
    title: 'BMI Calculator',
    desc: 'Calculate your Body Mass Index and see your weight category instantly.',
    icon: '&#9878;',
    kw: 'WHO standard',
  },
  {
    href: '/macro-calculator',
    title: 'Macro Calculator',
    desc: 'Get your daily protein, carbs, and fat targets for your specific goal.',
    icon: '&#129367;',
    kw: 'For weight loss & muscle gain',
  },
  {
    href: '/sleep-calculator',
    title: 'Sleep Calculator',
    desc: 'Find the best bedtimes or wake-up times based on 90-minute sleep cycles.',
    icon: '&#127769;',
    kw: 'Science-backed',
  },
  {
    href: '/ideal-weight-calculator',
    title: 'Ideal Weight Calculator',
    desc: 'Find your ideal body weight using four clinically validated formulas.',
    icon: '&#9878;',
    kw: 'Devine, Robinson, Miller, Hamwi',
  },
  {
    href: '/body-fat-calculator',
    title: 'Body Fat % Calculator',
    desc: 'Estimate your body fat percentage with just a tape measure. No calipers needed.',
    icon: '&#128198;',
    kw: 'U.S. Navy method',
  },
  {
    href: '/waist-to-hip-ratio-calculator',
    title: 'Waist-to-Hip Ratio Calculator',
    desc: 'Calculate your WHR and check your cardiovascular risk category using WHO standards.',
    icon: '&#128200;',
    kw: 'WHO risk categories',
  },
  {
    href: '/protein-calculator',
    title: 'Protein Calculator',
    desc: 'Find out exactly how much protein you need per day based on your weight, activity, and goal.',
    icon: '&#129372;',
    kw: 'ISSN guidelines',
  },
  {
    href: '/water-intake-calculator',
    title: 'Water Intake Calculator',
    desc: 'Find your personalized daily hydration target based on weight, activity, and climate.',
    icon: '&#128167;',
    kw: 'Personalized hydration',
  },
  {
    href: '/heart-rate-zone-calculator',
    title: 'Heart Rate Zone Calculator',
    desc: 'Calculate your 5 training zones by age or measured max heart rate.',
    icon: '&#128147;',
    kw: 'Tanaka formula · 5 zones',
  },
  {
    href: '/calories-burned-calculator',
    title: 'Calories Burned Calculator',
    desc: 'Calculate calories burned during 20+ activities using MET values from the Compendium of Physical Activities.',
    icon: '&#128293;',
    kw: 'MET · 20+ activities',
  },
  {
    href: '/one-rep-max-calculator',
    title: 'One Rep Max Calculator',
    desc: 'Calculate your 1RM for any lift using 4 validated formulas. Includes a full training percentage table.',
    icon: '&#127947;',
    kw: 'Epley · Brzycki · % table',
  },
];

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'HealthCalculation',
  url: SITE,
  description: 'Free health and fitness calculators for US adults.',
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Free Health &amp; Fitness Calculators &mdash; Calorie, BMI, Body Fat &amp; More</title>
  <meta name="description" content="Free online health calculators: calorie &amp; TDEE, BMI, macros, ideal weight, body fat percentage, sleep cycles and more. Instant results." />
  <link rel="canonical" href={SITE} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
  <!-- Cloudflare Web Analytics — replace TOKEN with your beacon token from dash.cloudflare.com > Analytics > Web Analytics -->
  <!-- <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "REPLACE_WITH_CF_ANALYTICS_TOKEN"}'></script> -->
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, Segoe UI, Roboto, Arial, sans-serif; color: #1f2937; background: #f6faf7; line-height: 1.65; }
    a { color: #16a34a; }
    .wrap { max-width: 1140px; margin: 0 auto; padding: 0 20px; }

    /* Header */
    .site-header { background: #fff; border-bottom: 1px solid #e5e7eb; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 0 #e5e7eb; }
    .site-header .wrap { display: flex; align-items: center; height: 58px; gap: 10px; }
    .logo { font-weight: 800; color: #16a34a; font-size: 16px; text-decoration: none; flex-shrink: 0; display: flex; align-items: center; gap: 7px; }
    .logo-mark { width: 28px; height: 28px; background: #16a34a; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 900; color: #fff; }
    .site-nav { display: flex; gap: 2px; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; flex: 1; justify-content: flex-start; }
    .site-nav::-webkit-scrollbar { display: none; }
    .site-nav a { color: #6b7280; text-decoration: none; font-size: 13px; font-weight: 500; padding: 6px 10px; border-radius: 7px; white-space: nowrap; flex-shrink: 0; transition: background .15s, color .15s; }
    .site-nav a:hover { background: #f0fdf4; color: #16a34a; }
    @media (max-width: 640px) {
      .site-header .wrap { height: auto; flex-direction: column; align-items: flex-start; padding-top: 10px; padding-bottom: 0; gap: 0; }
      .logo { padding-bottom: 8px; padding-left: 0; }
      .site-nav { width: calc(100% + 40px); margin-left: -20px; justify-content: flex-start; border-top: 1px solid #e5e7eb; padding: 6px 20px 8px; }
    }

    /* Hero */
    .hero { background: linear-gradient(135deg, #16a34a 0%, #0891b2 100%); color: #fff; padding: 60px 0 52px; text-align: center; }
    .hero h1 { font-size: 36px; font-weight: 900; margin-bottom: 12px; line-height: 1.15; }
    .hero p  { font-size: 17px; opacity: .9; max-width: 540px; margin: 0 auto; }
    @media (max-width: 600px) { .hero h1 { font-size: 26px; } }

    /* Tools grid */
    .tools-section { padding: 48px 0; }
    .tools-section h2 { font-size: 22px; font-weight: 800; margin-bottom: 20px; text-align: center; }
    .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; }
    .tool-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 22px 20px;
      text-decoration: none;
      color: #1f2937;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: box-shadow .18s, border-color .18s, transform .18s;
    }
    .tool-card:hover { box-shadow: 0 6px 24px rgba(22,163,74,.14); border-color: #86efac; transform: translateY(-2px); }
    .tool-icon  { font-size: 28px; }
    .tool-title { font-size: 16px; font-weight: 700; color: #1f2937; }
    .tool-desc  { font-size: 13px; color: #6b7280; flex: 1; }
    .tool-arrow { font-size: 18px; color: #16a34a; align-self: flex-end; }

    /* Guides section */
    .guides-section { padding: 48px 0; background: #f0fdf4; border-top: 1px solid #bbf7d0; }
    .guides-section h2 { font-size: 22px; font-weight: 800; margin-bottom: 8px; text-align: center; }
    .guides-section .section-sub { text-align: center; color: #6b7280; font-size: 14px; margin-bottom: 24px; }
    .guides-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
    .guide-card {
      background: #fff;
      border: 1px solid #bbf7d0;
      border-radius: 14px;
      padding: 22px 20px;
      text-decoration: none;
      color: #1f2937;
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: box-shadow .18s, border-color .18s, transform .18s;
    }
    .guide-card:hover { box-shadow: 0 6px 24px rgba(22,163,74,.14); border-color: #4ade80; transform: translateY(-2px); }
    .guide-card-icon { font-size: 26px; }
    .guide-card-title { font-size: 15px; font-weight: 700; color: #1f2937; }
    .guide-card-desc  { font-size: 13px; color: #6b7280; flex: 1; }
    .guide-card-cta   { font-size: 13px; font-weight: 600; color: #16a34a; margin-top: 4px; }

    /* Why section */
    .why-section { background: #fff; padding: 40px 0; border-top: 1px solid #e5e7eb; }
    .why-section h2 { font-size: 22px; font-weight: 800; margin-bottom: 20px; text-align: center; }
    .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
    .why-card  { text-align: center; padding: 16px; }
    .why-icon  { font-size: 28px; margin-bottom: 8px; }
    .why-title { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
    .why-desc  { font-size: 13px; color: #6b7280; }

    /* Footer */
    .site-footer { background: #fff; border-top: 1px solid #e5e7eb; padding: 24px 0; margin-top: 40px; }
    .site-footer .wrap { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10px; font-size: 13px; color: #6b7280; }
    .site-footer a { color: #6b7280; text-decoration: none; }
    .site-footer a:hover { color: #16a34a; }
    .footer-links { display: flex; gap: 16px; flex-wrap: wrap; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="wrap">
    <a class="logo" href="/">
      <span class="logo-mark" aria-hidden="true">H</span>
      HealthCalculation
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href="/bmr-calculator">BMR</a>
      <a href="/calorie-deficit-calculator">Deficit</a>
      <a href="/calorie-tdee-calculator">Calorie</a>
      <a href="/bmi-calculator">BMI</a>
      <a href="/macro-calculator">Macro</a>
      <a href="/ideal-weight-calculator">Ideal Wt</a>
      <a href="/body-fat-calculator">Body Fat</a>
      <a href="/waist-to-hip-ratio-calculator">WHR</a>
      <a href="/sleep-calculator">Sleep</a>
      <a href="/protein-calculator">Protein</a>
      <a href="/water-intake-calculator">Water</a>
      <a href="/heart-rate-zone-calculator">Heart Rate</a>
      <a href="/calories-burned-calculator">Cal Burned</a>
      <a href="/one-rep-max-calculator">1RM</a>
      <a href="/guides">Guides</a>
      <a href="/about">About</a>
    </nav>
  </div>
</header>

<section class="hero">
  <div class="wrap">
    <h1>Free Health &amp; Fitness Calculators</h1>
    <p>Accurate tools for calories, BMI, macros, sleep — and more. Built on clinically validated formulas.</p>
  </div>
</section>

<section class="tools-section">
  <div class="wrap">
    <h2>All Calculators</h2>
    <div class="tools-grid">
      {tools.map(({ href, title, desc, icon }) => (
        <a href={href} class="tool-card">
          <div class="tool-icon" set:html={icon} />
          <div class="tool-title">{title}</div>
          <div class="tool-desc">{desc}</div>
          <span class="tool-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="guides-section">
  <div class="wrap">
    <h2>Health &amp; Fitness Guides</h2>
    <p class="section-sub">Evidence-based articles to help you understand your results</p>
    <div class="guides-grid">
      <a href="/guides/how-much-protein-per-day" class="guide-card">
        <div class="guide-card-icon">&#129385;</div>
        <div class="guide-card-title">How Much Protein Do I Need Per Day?</div>
        <div class="guide-card-desc">ISSN-backed guidelines for muscle building, fat loss, and general health — with per-meal breakdown.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/healthy-bmi-for-women" class="guide-card">
        <div class="guide-card-icon">&#128202;</div>
        <div class="guide-card-title">What Is a Healthy BMI for Women?</div>
        <div class="guide-card-desc">WHO categories, age-group benchmarks, and why BMI alone doesn't tell the full story.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/how-to-calculate-tdee" class="guide-card">
        <div class="guide-card-icon">&#128293;</div>
        <div class="guide-card-title">How to Calculate TDEE Accurately</div>
        <div class="guide-card-desc">Step-by-step walkthrough of the Mifflin-St Jeor equation with activity multipliers and common mistakes.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/how-many-calories-does-walking-burn" class="guide-card">
        <div class="guide-card-icon">&#128694;</div>
        <div class="guide-card-title">How Many Calories Does Walking Burn?</div>
        <div class="guide-card-desc">Calorie tables by weight, speed, and duration — plus the MET formula and 5 tips to burn more on every walk.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/healthy-body-fat-percentage" class="guide-card">
        <div class="guide-card-icon">&#128198;</div>
        <div class="guide-card-title">What Is a Healthy Body Fat Percentage?</div>
        <div class="guide-card-desc">ACE and ACSM ranges for men and women by age — plus measurement methods compared and health risk thresholds.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/how-much-water-should-i-drink" class="guide-card">
        <div class="guide-card-icon">&#128167;</div>
        <div class="guide-card-title">How Much Water Should I Drink Per Day?</div>
        <div class="guide-card-desc">NASEM targets by body weight and activity level — plus a urine color hydration chart and tips to stay hydrated.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/healthy-heart-rate-by-age" class="guide-card">
        <div class="guide-card-icon">&#128147;</div>
        <div class="guide-card-title">What Is a Healthy Heart Rate by Age?</div>
        <div class="guide-card-desc">Normal resting HR ranges by age, max heart rate by the Tanaka formula, and all 5 training zones explained.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/what-is-my-ideal-weight" class="guide-card">
        <div class="guide-card-icon">&#9878;</div>
        <div class="guide-card-title">What Is My Ideal Weight?</div>
        <div class="guide-card-desc">Devine, Robinson, Miller, and Hamwi formulas compared by height and sex — plus why IBW has real limitations.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/how-to-calculate-macros" class="guide-card">
        <div class="guide-card-icon">&#129367;</div>
        <div class="guide-card-title">How to Calculate Your Macros</div>
        <div class="guide-card-desc">TDEE to gram targets in 4 steps — ratio tables for cutting, bulking, and maintenance.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/how-to-use-one-rep-max" class="guide-card">
        <div class="guide-card-icon">&#127947;</div>
        <div class="guide-card-title">How to Use Your One Rep Max</div>
        <div class="guide-card-desc">Training percentage zones, strength standards by body weight, and 1RM-based periodization explained.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/what-is-basal-metabolic-rate" class="guide-card">
        <div class="guide-card-icon">&#128200;</div>
        <div class="guide-card-body">
          <div class="guide-card-title">What Is Basal Metabolic Rate (BMR)?</div>
          <div class="guide-card-desc">BMR explained — Mifflin-St Jeor vs Harris-Benedict, normal ranges by age, and how to use BMR to set your calorie goal.</div>
          <div class="guide-card-cta">Read guide &rarr;</div>
        </div>
      </a>
      <a href="/guides/how-to-create-a-calorie-deficit" class="guide-card">
        <div class="guide-card-icon">&#9986;</div>
        <div class="guide-card-body">
          <div class="guide-card-title">How to Create a Calorie Deficit</div>
          <div class="guide-card-desc">Safe deficit sizes, minimum calorie floors, why plateaus happen, and how to adjust when weight loss stalls.</div>
          <div class="guide-card-cta">Read guide &rarr;</div>
        </div>
      </a>
      <a href="/guides/how-much-sleep-do-i-need" class="guide-card">
        <div class="guide-card-icon">&#127769;</div>
        <div class="guide-card-title">How Much Sleep Do I Need by Age?</div>
        <div class="guide-card-desc">AASM guidelines by age, the science of sleep cycles, and 5 evidence-based tips to wake up refreshed.</div>
        <div class="guide-card-cta">Read guide &rarr;</div>
      </a>
      <a href="/guides/healthy-waist-to-hip-ratio" class="guide-card">
        <div class="guide-card-icon">&#128200;</div>
        <div class="guide-card-body">
          <div class="guide-card-title">What Is a Healthy Waist-to-Hip Ratio?</div>
          <div class="guide-card-desc">WHO thresholds explained, WHR vs BMI comparison, how visceral fat drives metabolic risk, and evidence-based ways to improve your ratio.</div>
          <div class="guide-card-cta">Read guide &rarr;</div>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="why-section">
  <div class="wrap">
    <h2>Why Use HealthCalculation?</h2>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">&#128300;</div>
        <div class="why-title">Clinically Validated</div>
        <div class="why-desc">Mifflin-St Jeor, WHO BMI standards, AASM sleep guidelines</div>
      </div>
      <div class="why-card">
        <div class="why-icon">&#9889;</div>
        <div class="why-title">Instant Results</div>
        <div class="why-desc">Client-side calculations — no sign-up, no waiting</div>
      </div>
      <div class="why-card">
        <div class="why-icon">&#128241;</div>
        <div class="why-title">Mobile-Friendly</div>
        <div class="why-desc">Works perfectly on any device, any screen size</div>
      </div>
      <div class="why-card">
        <div class="why-icon">&#128274;</div>
        <div class="why-title">Privacy First</div>
        <div class="why-desc">No data stored — all calculations stay in your browser</div>
      </div>
    </div>
  </div>
</section>

<footer class="site-footer">
  <div class="wrap">
        <p>&copy; 2025 HealthCalculation.com &mdash; For informational purposes only. Not medical advice.</p>
    <div class="footer-links">
      <a href="/about">About</a>
      <a href="/privacy">Privacy</a>
      <a href="/disclaimer">Disclaimer</a>
    </div>
  </div>
</footer>

</body>
</html>

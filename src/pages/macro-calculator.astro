---
import ToolLayout from '../layouts/ToolLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { AFF } from '../config/site';

const SITE = 'https://healthcalculation.com';

const faq = [
  {
    q: 'What are macros and why do they matter?',
    a: 'Macronutrients ("macros") are the three main categories of calories: protein, carbohydrates, and fat. Total calories determine whether you gain or lose weight, but your macro split determines how much of that change is muscle vs. fat, how full you feel, and how well you perform. High protein preserves muscle during a calorie deficit.',
  },
  {
    q: 'How much protein do I need per day?',
    a: 'Current evidence suggests 1.6–2.2 g of protein per kg of body weight per day (0.7–1.0 g/lb) for people who resistance train. For sedentary adults, 0.8 g/kg (0.36 g/lb) meets minimum needs. This calculator uses TDEE percentage splits, which for most active people lands in the 1.6–2.0 g/kg range.',
  },
  {
    q: 'What is the best macro ratio for weight loss?',
    a: 'Research supports a higher-protein approach (35–40% of calories) for weight loss because protein preserves lean mass and increases satiety. Carbohydrate and fat ratios are more flexible — both low-carb and moderate-carb approaches can be effective as long as protein is adequate and you are in a calorie deficit.',
  },
  {
    q: 'Should I track macros or just calories?',
    a: 'For beginners, tracking total calories is often sufficient and simpler. If you want to preserve muscle during weight loss, improve athletic performance, or fine-tune your diet after a plateau, tracking macros — especially protein — adds significant value. Many people start with calories and layer in macro tracking as they progress.',
  },
  {
    q: 'Should I count net carbs or total carbs?',
    a: 'For general fitness goals, total carbs is the standard approach used by most nutrition databases and apps. Net carbs (total carbs minus fiber) is a concept primarily used in ketogenic diets. Unless you are following a strict low-carb protocol, tracking total carbs keeps things simpler and consistent.',
  },
];

const affiliates = [
  {
    href: AFF.trifecta,
    label: 'Trifecta Nutrition',
    sub: 'Macro-balanced meal prep · Organic, chef-prepared meals',
    badge: 'Top Pick',
  },
  {
    href: AFF.greenChef,
    label: 'Green Chef',
    sub: 'Keto & paleo meal kits · USDA-certified organic',
  },
  {
    href: AFF.transparentLabs,
    label: 'Transparent Labs',
    sub: 'High-quality protein supplements · No artificial fillers',
  },
];

const related = [
  { href: '/calorie-tdee-calculator', label: 'Calorie Calculator', desc: 'Find your TDEE first' },
  { href: '/bmi-calculator',          label: 'BMI Calculator',     desc: 'Check your weight category' },
  { href: '/sleep-calculator',        label: 'Sleep Calculator',   desc: 'Sleep affects metabolism too' },
];

const schemaApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Macro Calculator',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  url: `${SITE}/macro-calculator`,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Free macro calculator. Find your daily protein, carbs, and fat targets based on your goal.',
};
---

<ToolLayout
  title="Macro Calculator — Daily Protein, Carbs & Fat Targets (Free)"
  description="Calculate your daily macro targets — protein, carbohydrates, and fat — based on your weight, activity level, and goal. Free macronutrient calculator."
  canonical={`${SITE}/macro-calculator`}
  schemaApp={schemaApp}
  schemaFaq={faq}
>

  <div class="page-layout">
    <div class="main-col">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>›</span><span>Macro Calculator</span>
      </nav>

      <h1>Macro Calculator</h1>
      <p class="lead">
        Get your personalized <strong>protein, carbohydrate, and fat targets</strong> based on
        your body stats and goal. Works for weight loss, muscle gain, and maintenance.
      </p>

      <div class="card">
        <form id="macroForm" novalidate>
          <!-- Units -->
          <div class="field-group" style="margin-bottom:16px">
            <label class="field-label">Units</label>
            <div class="seg-group">
              <label class="seg-opt"><input type="radio" name="units" value="us" checked /><span>US (lbs, ft/in)</span></label>
              <label class="seg-opt"><input type="radio" name="units" value="metric" /><span>Metric (kg, cm)</span></label>
            </div>
          </div>
          <!-- Sex -->
          <div class="field-group" style="margin-bottom:16px">
            <label class="field-label">Biological Sex</label>
            <div class="seg-group">
              <label class="seg-opt"><input type="radio" name="sex" value="m" checked /><span>Male</span></label>
              <label class="seg-opt"><input type="radio" name="sex" value="f" /><span>Female</span></label>
            </div>
          </div>
          <!-- Age / Weight / Height -->
          <div class="grid-3">
            <div class="field-group">
              <label class="field-label" for="mAge">Age</label>
              <input type="number" id="mAge" name="age" min="15" max="100" placeholder="28" required />
            </div>
            <div class="field-group">
              <label class="field-label" for="mWeight">Weight</label>
              <input type="number" id="mWeight" name="weight" min="1" placeholder="155" required />
              <span class="field-unit" id="mWeightUnit">lbs</span>
            </div>
            <div class="field-group">
              <label class="field-label">Height</label>
              <div class="ft-in" id="mFtIn">
                <input type="number" id="mFt" name="heightFt" min="3" max="8" placeholder="5" aria-label="Feet" />
                <span class="field-sep">ft</span>
                <input type="number" id="mIn" name="heightIn" min="0" max="11" placeholder="7" aria-label="Inches" />
                <span class="field-sep">in</span>
              </div>
              <input type="number" id="mCm" name="heightCm" min="100" max="250" placeholder="170" style="display:none" aria-label="Height cm" />
            </div>
          </div>
          <!-- Activity + Goal + Diet -->
          <div class="grid-3" style="margin-top:14px">
            <div class="field-group">
              <label class="field-label" for="mActivity">Activity Level</label>
              <select id="mActivity" name="activity">
                <option value="1.2">Sedentary</option>
                <option value="1.375">Lightly active</option>
                <option value="1.55" selected>Moderately active</option>
                <option value="1.725">Very active</option>
                <option value="1.9">Extra active</option>
              </select>
            </div>
            <div class="field-group">
              <label class="field-label" for="mGoal">Goal</label>
              <select id="mGoal" name="goal">
                <option value="-500">Lose 1 lb/wk (−500 cal)</option>
                <option value="-250">Lose 0.5 lb/wk (−250 cal)</option>
                <option value="0" selected>Maintain weight</option>
                <option value="250">Gain 0.5 lb/wk (+250 cal)</option>
                <option value="500">Gain 1 lb/wk (+500 cal)</option>
              </select>
            </div>
            <div class="field-group">
              <label class="field-label" for="mDiet">Diet Style</label>
              <select id="mDiet" name="diet">
                <option value="balanced">Balanced (30/40/30)</option>
                <option value="highprotein">High Protein (40/30/30)</option>
                <option value="keto">Keto (5/70/25)</option>
                <option value="lowfat">Low Fat (25/55/20)</option>
              </select>
            </div>
          </div>

          <button type="submit" class="btn-calc">Calculate My Macros →</button>
        </form>

        <div id="macroResults" hidden>
          <div class="macro-total" id="macroTotal"></div>
          <div class="macro-bars" id="macroBars"></div>
          <div class="macro-grid" id="macroGrid"></div>
          <Disclaimer short={true} />
        </div>
      </div>

      <div id="macroAff" hidden>
        <AffiliateCTA heading="Hit Your Macro Targets Every Day" items={affiliates} />
      </div>

      <AdSlot label="In-content" />

      <h2>How Macros Are Calculated</h2>
      <p>
        First we calculate your <strong>TDEE</strong> (Total Daily Energy Expenditure) using the
        Mifflin-St Jeor formula, then apply your calorie adjustment (goal). Finally, we split
        calories into protein, carbs, and fat based on your chosen diet style.
      </p>
      <div class="macro-table">
        <div class="mt-row header"><span>Diet Style</span><span>Protein</span><span>Carbs</span><span>Fat</span></div>
        <div class="mt-row"><span>Balanced</span><span>30%</span><span>40%</span><span>30%</span></div>
        <div class="mt-row"><span>High Protein</span><span>40%</span><span>30%</span><span>30%</span></div>
        <div class="mt-row"><span>Keto</span><span>25%</span><span>5%</span><span>70%</span></div>
        <div class="mt-row"><span>Low Fat</span><span>25%</span><span>55%</span><span>20%</span></div>
      </div>
      <Disclaimer />
    </div>

    <aside class="sidebar">
      <AdSlot label="Sidebar" format="rectangle" />
      <div class="card" style="font-size:13px;color:#374151">
        <p style="font-weight:700;margin-bottom:10px">Calorie Density</p>
        <p>🥩 Protein — 4 cal / gram</p>
        <p>🌾 Carbohydrates — 4 cal / gram</p>
        <p>🧈 Fat — 9 cal / gram</p>
        <p style="margin-bottom:0">💪 Target 0.7–1 g protein per lb of bodyweight for muscle growth</p>
      </div>
    </aside>
  </div>


<!-- FAQ -->
<!-- Who Should Use -->
<section class="content-section">
  <h2>Who Should Use This Calculator?</h2>
  <p>This calculator suits anyone following a structured eating plan: people in a cutting or bulking phase, those on low-carb or ketogenic diets who want precise carb targets, athletes needing higher protein for muscle repair, and coaches setting client nutrition targets. It is not a substitute for a registered dietitian for people with medical conditions such as kidney disease, diabetes, or eating disorders, where macronutrient ratios require clinical supervision.</p>
</section>

<!-- Tips for Accuracy -->
<section class="content-section">
  <h2>Tips for Accurate Results</h2>
  <p>Round your macro targets to the nearest 5 grams for practical meal planning — hitting exact grams daily is unnecessary. Prioritize hitting your protein target first, then carbs, and let fat fill the remaining calories. Use a food scale for at least the first month to build accurate portion intuition. Re-calculate macros every 4–6 weeks or after a 5 lb weight change, as your TDEE and goals evolve.</p>
</section>

<section class="content-section">
  <h2>Frequently Asked Questions</h2>
  {faq.map(({ q, a }) => (
    <details class="faq-item">
      <summary>{q}</summary>
      <p set:html={a} />
    </details>
  ))}
</section>


<!-- How it works -->
<section class="content-section">
  <h2>How Macros Are Calculated</h2>
  <p>Your macro targets are derived from your TDEE (calculated via the Mifflin-St Jeor formula), then split into protein, carbohydrates, and fat based on your goal. Each goal uses a research-backed ratio:</p>
  <div class="formula-box">
    Weight Loss: Protein 40% &mdash; Carbs 35% &mdash; Fat 25%<br>
    Maintenance: Protein 30% &mdash; Carbs 40% &mdash; Fat 30%<br>
    Muscle Gain: Protein 30% &mdash; Carbs 45% &mdash; Fat 25%<br><br>
    Calories per gram: Protein = 4 kcal &mdash; Carbs = 4 kcal &mdash; Fat = 9 kcal
  </div>
  <p>These ratios are starting points. Individual responses vary &mdash; adjust protein up if you are strength training, or carbs down if you prefer a lower-carb approach.</p>
</section>


<!-- Related -->
<section class="content-section">
  <h2>Related Calculators</h2>
  <div class="related-grid">
    <a href="/calorie-tdee-calculator" class="related-link">&#128293; Calorie &amp; TDEE</a>
    <a href="/bmi-calculator" class="related-link">&#9878; BMI Calculator</a>
    <a href="/ideal-weight-calculator" class="related-link">&#9878; Ideal Weight</a>
    <a href="/body-fat-calculator" class="related-link">&#37; Body Fat %</a>
  </div>
</section>


<!-- Guide CTA -->
<div class="guide-cta-box" style="margin-top:32px">
  <div class="gcta-icon">&#128214;</div>
  <div class="gcta-body">
    <div class="gcta-label">Related Guide</div>
    <a href="/guides/how-to-calculate-macros" class="gcta-title">How to Calculate Your Macros</a>
    <p class="gcta-desc">Step-by-step: TDEE → calorie target → macro ratio → grams. Includes ratio tables for cutting, bulking, and maintenance, plus the 5 most common macro mistakes.</p>
  </div>
  <a href="/guides/how-to-calculate-macros" class="gcta-btn">Read guide &rarr;</a>
</div>

</ToolLayout>

<script>
const form    = document.getElementById('macroForm') as HTMLFormElement;
const results = document.getElementById('macroResults') as HTMLDivElement;
const affSec  = document.getElementById('macroAff') as HTMLDivElement;

// Unit toggle
document.querySelectorAll<HTMLInputElement>('input[name="units"]').forEach(r => {
  r.addEventListener('change', () => {
    const isUS = r.value === 'us';
    (document.getElementById('mFtIn') as HTMLElement).style.display   = isUS ? 'flex' : 'none';
    (document.getElementById('mCm')   as HTMLElement).style.display   = isUS ? 'none' : 'block';
    (document.getElementById('mWeightUnit') as HTMLElement).textContent = isUS ? 'lbs' : 'kg';
  });
});

const dietRatios: Record<string, [number, number, number]> = {
  balanced:    [0.30, 0.40, 0.30],
  highprotein: [0.40, 0.30, 0.30],
  keto:        [0.25, 0.05, 0.70],
  lowfat:      [0.25, 0.55, 0.20],
};

form.addEventListener('submit', e => {
  e.preventDefault();
  const fd = new FormData(form);
  const units    = fd.get('units') as string;
  const sex      = fd.get('sex') as string;
  const age      = parseFloat(fd.get('age') as string);
  const activity = parseFloat(fd.get('activity') as string);
  const goalAdj  = parseFloat(fd.get('goal') as string);
  const diet     = fd.get('diet') as string;

  let weightKg: number, heightCm: number;
  if (units === 'us') {
    weightKg = parseFloat(fd.get('weight') as string) * 0.453592;
    const ft = parseFloat(fd.get('heightFt') as string) || 0;
    const inc = parseFloat(fd.get('heightIn') as string) || 0;
    heightCm = (ft * 12 + inc) * 2.54;
  } else {
    weightKg = parseFloat(fd.get('weight') as string);
    heightCm = parseFloat(fd.get('heightCm') as string);
  }
  if (!age || !weightKg || !heightCm) return;

  const s    = sex === 'm' ? 5 : -161;
  const bmr  = 10 * weightKg + 6.25 * heightCm - 5 * age + s;
  const tdee = bmr * activity + goalAdj;
  const calories = Math.max(tdee, 1200);

  const [pPct, cPct, fPct] = dietRatios[diet] || dietRatios.balanced;
  const proteinG = Math.round((calories * pPct) / 4);
  const carbsG   = Math.round((calories * cPct) / 4);
  const fatG     = Math.round((calories * fPct) / 9);

  const colors = { protein: '#16a34a', carbs: '#0891b2', fat: '#f59e0b' };
  const totalEl = document.getElementById('macroTotal')!;
  totalEl.innerHTML = `<span class="total-cal">${Math.round(calories).toLocaleString()}</span><span class="total-label">calories/day</span>`;

  const barsEl = document.getElementById('macroBars')!;
  barsEl.innerHTML = `
    <div class="macro-bar-row">
      <span style="color:${colors.protein}">Protein</span>
      <div class="bar-track"><div class="bar-fill" style="width:${pPct*100}%;background:${colors.protein}"></div></div>
      <span>${Math.round(pPct*100)}%</span>
    </div>
    <div class="macro-bar-row">
      <span style="color:${colors.carbs}">Carbs</span>
      <div class="bar-track"><div class="bar-fill" style="width:${cPct*100}%;background:${colors.carbs}"></div></div>
      <span>${Math.round(cPct*100)}%</span>
    </div>
    <div class="macro-bar-row">
      <span style="color:${colors.fat}">Fat</span>
      <div class="bar-track"><div class="bar-fill" style="width:${fPct*100}%;background:${colors.fat}"></div></div>
      <span>${Math.round(fPct*100)}%</span>
    </div>`;

  const gridEl = document.getElementById('macroGrid')!;
  gridEl.innerHTML = `
    <div class="m-kpi" style="--c:${colors.protein}"><div class="m-v">${proteinG}g</div><div class="m-l">Protein</div><div class="m-cal">${proteinG*4} cal</div></div>
    <div class="m-kpi" style="--c:${colors.carbs}"><div class="m-v">${carbsG}g</div><div class="m-l">Carbohydrates</div><div class="m-cal">${carbsG*4} cal</div></div>
    <div class="m-kpi" style="--c:${colors.fat}"><div class="m-v">${fatG}g</div><div class="m-l">Fat</div><div class="m-cal">${fatG*9} cal</div></div>`;

  results.hidden = false;
  if (affSec) affSec.hidden = false;  // CTA tự ẩn nếu chưa có link affiliate thật (xem src/config/site.ts)
  results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>

<style>


  /* Results */
  #macroResults { margin-top: 20px; padding-top: 18px; border-top: 1px solid #e5e7eb; }
  .macro-total { display: flex; align-items: baseline; gap: 8px; margin-bottom: 16px; }
  .total-cal { font-size: 40px; font-weight: 900; color: #16a34a; }
  .total-label { font-size: 14px; color: #6b7280; }
  .macro-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 13px; font-weight: 600; }
  .macro-bar-row > span:first-child { width: 56px; }
  .macro-bar-row > span:last-child  { width: 36px; text-align: right; color: #6b7280; }
  .bar-track { flex: 1; height: 10px; background: #f1f5f9; border-radius: 5px; overflow: hidden; }
  .bar-fill  { height: 100%; border-radius: 5px; transition: width .4s ease; }
  .macro-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-top: 14px; }
  @media (max-width: 480px) { .macro-grid { grid-template-columns: 1fr; } }
  .m-kpi { background: #f9fafb; border-radius: 10px; padding: 14px; border-left: 3px solid var(--c); }
  .m-v   { font-size: 26px; font-weight: 800; color: var(--c); }
  .m-l   { font-size: 12px; color: #6b7280; margin-top: 1px; }
  .m-cal { font-size: 11px; color: #9ca3af; margin-top: 2px; }

  .macro-table { border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; margin: 14px 0; font-size: 14px; }
  .mt-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; padding: 10px 14px; border-bottom: 1px solid #e5e7eb; }
  .mt-row:last-child { border-bottom: none; }
  .mt-row.header { background: #f9fafb; font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: .4px; color: #6b7280; }
</style>
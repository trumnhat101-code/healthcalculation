---
import ToolLayout from '../layouts/ToolLayout.astro';

const SITE = 'https://healthcalculation.com';
const canonical = `${SITE}/ideal-weight-calculator`;

const schemaApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Ideal Weight Calculator',
  url: canonical,
  description: 'Calculate your ideal body weight using four clinically validated formulas: Devine, Robinson, Miller, and Hamwi.',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const schemaFaq = [
  {
    q: 'Which ideal weight formula is most accurate?',
    a: 'No single formula is universally "most accurate" — they were developed for different populations. The Devine formula is most widely used in clinical settings (e.g., for medication dosing). Looking at the range across all four formulas gives a more realistic picture than relying on one number.',
  },
  {
    q: 'What is the Devine formula?',
    a: 'Developed by Dr. B.J. Devine in 1974, originally for pharmaceutical dosing. For men: 50 kg + 2.3 kg per inch over 5 feet. For women: 45.5 kg + 2.3 kg per inch over 5 feet.',
  },
  {
    q: 'Is ideal weight the same as a healthy BMI weight?',
    a: 'Not exactly. BMI-based healthy weight covers a range (BMI 18.5–24.9), while ideal weight formulas give a single target number. The ideal weight range shown here uses the minimum and maximum across four formulas, which typically falls within the healthy BMI range.',
  },
  {
    q: 'Can I be healthy above my ideal weight?',
    a: 'Yes. Ideal weight formulas do not account for muscle mass, bone density, age, or fitness level. A muscular athlete may exceed the ideal weight range while being metabolically healthy. Use these numbers as a rough guide, not a rigid target.',
  },
  {
    q: 'How is ideal weight different from goal weight?',
    a: 'Ideal weight is a formula-based estimate of a healthy weight for your height and sex. Goal weight is personal — it may be higher or lower depending on your fitness goals, body composition, and how you feel. Many people set a goal weight within or near their ideal weight range.',
  },
];
---

<ToolLayout
  title="Ideal Weight Calculator — Devine, Robinson, Miller & Hamwi Formulas"
  description="Find your ideal body weight using four clinically validated formulas. Enter your height and sex for an instant result in lbs and kg."
  canonical={canonical}
  schemaApp={schemaApp}
  schemaFaq={schemaFaq}
  pageIcon="&#9878;"
  heroTitle="Ideal Weight Calculator"
>

<div class="tool-card">
  <h1 class="tool-title">Ideal Weight Calculator</h1>
  <p class="tool-subtitle">Based on 4 clinically validated formulas</p>

  <form id="iw-form" onsubmit="return false">

    <div class="field-group" style="margin-bottom:16px">
      <span class="field-label">Sex</span>
      <div class="seg-group">
        <label class="seg-opt">
          <input type="radio" name="sex" value="male" checked />
          <span>Male</span>
        </label>
        <label class="seg-opt">
          <input type="radio" name="sex" value="female" />
          <span>Female</span>
        </label>
      </div>
    </div>

    <div class="field-group" style="margin-bottom:16px">
      <span class="field-label">Unit system</span>
      <div class="seg-group">
        <label class="seg-opt">
          <input type="radio" name="unit" value="imperial" checked />
          <span>Imperial (ft/in)</span>
        </label>
        <label class="seg-opt">
          <input type="radio" name="unit" value="metric" />
          <span>Metric (cm)</span>
        </label>
      </div>
    </div>

    <div id="height-imperial">
      <div class="grid-2">
        <div class="field-group">
          <label class="field-label" for="iw-ft">Feet</label>
          <input type="number" id="iw-ft" min="3" max="8" value="5" />
        </div>
        <div class="field-group">
          <label class="field-label" for="iw-in">Inches</label>
          <input type="number" id="iw-in" min="0" max="11" value="9" />
        </div>
      </div>
    </div>
    <div id="height-metric" style="display:none">
      <div class="field-group">
        <label class="field-label" for="iw-cm">Height (cm)</label>
        <div class="field-group">
          <input type="number" id="iw-cm" min="100" max="250" value="175" />
          <span class="field-unit">cm</span>
        </div>
      </div>
    </div>

    <button class="btn-calc" type="button" onclick="calcIdealWeight()">Calculate Ideal Weight</button>
  </form>

  <div id="iw-results" style="display:none; margin-top:24px">
    <div class="iw-range-card">
      <p class="iw-range-label">Your Ideal Weight Range</p>
      <p class="iw-range-value" id="iw-range-lbs">—</p>
      <p class="iw-range-kg" id="iw-range-kg">—</p>
    </div>
    <table class="result-table" style="margin-top:16px">
      <thead>
        <tr><th>Formula</th><th>lbs</th><th>kg</th></tr>
      </thead>
      <tbody id="iw-table-body"></tbody>
    </table>
    <p style="font-size:12px;color:#9ca3af;margin-top:10px">These are estimates. Consult a healthcare provider for personalized guidance.</p>
  </div>
</div>

<!-- How it works -->
<section class="content-section">
  <h2>How the Formulas Work</h2>
  <p>All four formulas use height and sex as inputs, and express ideal weight in kilograms. Each was developed independently for different clinical contexts:</p>
  <div class="formula-box">
    Devine (1974) &mdash; Male: 50 + 2.3 &times; (inches above 60)<br>
    Devine (1974) &mdash; Female: 45.5 + 2.3 &times; (inches above 60)<br><br>
    Robinson (1983) &mdash; Male: 52 + 1.9 &times; (inches above 60)<br>
    Robinson (1983) &mdash; Female: 49 + 1.7 &times; (inches above 60)<br><br>
    Miller (1983) &mdash; Male: 56.2 + 1.41 &times; (inches above 60)<br>
    Miller (1983) &mdash; Female: 53.1 + 1.36 &times; (inches above 60)<br><br>
    Hamwi (1964) &mdash; Male: 48.1 + 2.72 &times; (inches above 60)<br>
    Hamwi (1964) &mdash; Female: 45.4 + 2.27 &times; (inches above 60)
  </div>
  <p>The <strong>range</strong> shown is the spread from the lowest to highest formula result, giving you a realistic target zone rather than a single arbitrary number.</p>
</section>

<!-- FAQ -->
<section class="content-section">
  <h2>Frequently Asked Questions</h2>
  <div class="faq-list">
    {schemaFaq.map(({ q, a }) => (
      <details class="faq-item">
        <summary>{q}</summary>
        <div class="faq-body"><p>{a}</p></div>
      </details>
    ))}
  </div>
</section>

<!-- Related tools -->
<section class="content-section">
  <h2>Related Calculators</h2>
  <div class="related-grid">
    <a href="/bmi-calculator" class="related-link">&#9878; BMI Calculator</a>
    <a href="/body-fat-calculator" class="related-link">&#37; Body Fat Calculator</a>
    <a href="/calorie-tdee-calculator" class="related-link">&#128293; Calorie &amp; TDEE</a>
    <a href="/macro-calculator" class="related-link">&#9881; Macro Calculator</a>
  </div>
</section>

<style>
  .tool-title  { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
  .tool-subtitle { font-size: 14px; color: var(--mut); margin-bottom: 20px; }

  .iw-range-card {
    background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
    border: 2px solid #86efac;
    border-radius: 14px;
    padding: 20px;
    text-align: center;
  }
  .iw-range-label { font-size: 13px; font-weight: 700; color: var(--mut); text-transform: uppercase; letter-spacing: .4px; margin-bottom: 6px; }
  .iw-range-value { font-size: 28px; font-weight: 900; color: var(--ac); }
  .iw-range-kg    { font-size: 16px; color: #6b7280; margin-top: 2px; }
</style>

<script>
function getHeightInches() {
  const unit = document.querySelector('input[name="unit"]:checked').value;
  if (unit === 'imperial') {
    const ft = parseFloat(document.getElementById('iw-ft').value) || 0;
    const inches = parseFloat(document.getElementById('iw-in').value) || 0;
    return ft * 12 + inches;
  } else {
    const cm = parseFloat(document.getElementById('iw-cm').value) || 0;
    return cm / 2.54;
  }
}

function calcIdealWeight() {
  const sex = document.querySelector('input[name="sex"]:checked').value;
  const h = getHeightInches();
  if (!h || h < 36 || h > 96) return;

  const over60 = Math.max(0, h - 60);
  const formulas = [
    { name: 'Devine (1974)',   kg: sex === 'male' ? 50   + 2.3  * over60 : 45.5 + 2.3  * over60 },
    { name: 'Robinson (1983)', kg: sex === 'male' ? 52   + 1.9  * over60 : 49   + 1.7  * over60 },
    { name: 'Miller (1983)',   kg: sex === 'male' ? 56.2 + 1.41 * over60 : 53.1 + 1.36 * over60 },
    { name: 'Hamwi (1964)',    kg: sex === 'male' ? 48.1 + 2.72 * over60 : 45.4 + 2.27 * over60 },
  ];

  const weights = formulas.map(f => f.kg);
  const minKg = Math.min(...weights);
  const maxKg = Math.max(...weights);
  const minLbs = minKg * 2.20462;
  const maxLbs = maxKg * 2.20462;

  document.getElementById('iw-range-lbs').textContent =
    Math.round(minLbs) + ' – ' + Math.round(maxLbs) + ' lbs';
  document.getElementById('iw-range-kg').textContent =
    minKg.toFixed(1) + ' – ' + maxKg.toFixed(1) + ' kg';

  const tbody = document.getElementById('iw-table-body');
  tbody.innerHTML = formulas.map(f => {
    const lbs = (f.kg * 2.20462).toFixed(1);
    return '<tr><td>' + f.name + '</td><td>' + lbs + ' lbs</td><td>' + f.kg.toFixed(1) + ' kg</td></tr>';
  }).join('');

  document.getElementById('iw-results').style.display = 'block';
}

// Toggle height inputs
document.querySelectorAll('input[name="unit"]').forEach(r => {
  r.addEventListener('change', () => {
    const imp = r.value === 'imperial';
    document.getElementById('height-imperial').style.display = imp ? '' : 'none';
    document.getElementById('height-metric').style.display   = imp ? 'none' : '';
  });
});
</script>

</ToolLayout>

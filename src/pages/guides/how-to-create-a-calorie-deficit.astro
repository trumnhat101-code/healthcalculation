  </div>

  <!-- Related Guides -->
  <section class="content-section">
    <h2>Related Guides</h2>
    <div class="related-grid">
      <a href="/guides/how-to-calculate-tdee" class="related-link">&#128293; How to Calculate Your TDEE</a>
      <a href="/guides/how-to-calculate-macros" class="related-link">&#129367; How to Calculate Your Macros</a>
      <a href="/guides/what-is-basal-metabolic-rate" class="related-link">&#128200; What Is Basal Metabolic Rate?</a>
    </div>
  </section>

</div>


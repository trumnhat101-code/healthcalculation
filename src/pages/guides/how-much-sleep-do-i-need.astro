const SITE = 'https://healthcalculation.com';
const canonical = `${SITE}/guides/how-much-sleep-do-i-need`;

const schemaArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'How Much Sleep Do I Need by Age?',
  description: 'AASM and NSF sleep recommendations by age group, the science of sleep cycles, signs of sleep deprivation, and how to optimize your sleep schedule.',
  url: canonical,
  datePublished: '2026-06-18',
  dateModified: '2026-06-19',
  author: { '@type': 'Organization', name: 'HealthCalculation.com' },
  publisher: { '@type': 'Organization', name: 'HealthCalculation.com', url: SITE },
};

const schemaFaq = [
  {
    q: 'How much sleep do adults need per night?',
    a: 'The American Academy of Sleep Medicine (AASM) and the Centers for Disease Control (CDC) recommend 7 or more hours of sleep per night for adults aged 18-60. Adults aged 61-64 need 7-9 hours, and those 65 and older need 7-8 hours. The National Sleep Foundation refines this to 7-9 hours for most adults (18-64), with 6 hours as the minimum acceptable threshold for adults under 65.',
  },
  {
    q: 'What happens if you sleep less than 7 hours?',
    a: 'Consistently sleeping less than 7 hours is associated with impaired cognitive performance (equivalent to 1-2 days of total sleep deprivation at 6 hours/night), increased risk of obesity (24% higher at 5-6 hours vs 7-8 hours), type 2 diabetes, cardiovascular disease, and reduced immune function. Reaction time and decision-making degrade significantly after just one night of 6 hours or less.',
  },
  {
    q: 'What is a sleep cycle and how long does it last?',
    a: 'A sleep cycle lasts approximately 90 minutes and consists of four stages: N1 (light sleep, 5-10 min), N2 (light sleep, 20-25 min), N3 (deep/slow-wave sleep, 20-40 min), and REM sleep (10-60 min, increasing with each cycle). Adults complete 4-6 cycles per night. Deep sleep (N3) dominates early cycles; REM sleep dominates later cycles and is critical for memory consolidation and emotional processing.',
  },
  {
    q: 'Is it better to wake up at the end of a sleep cycle?',
    a: 'Yes. Waking at the end of a 90-minute cycle — rather than mid-cycle — results in feeling more alert and refreshed. This is why 7.5 hours (5 cycles) or 9 hours (6 cycles) often feel better than exactly 8 hours for some people. The sleep calculator uses this principle to suggest optimal wake times based on when you plan to fall asleep.',
  },
  {
    q: 'Can you catch up on lost sleep on weekends?',
    a: 'Partially, but not fully. Research shows that weekend recovery sleep can reduce some metabolic and cognitive deficits from weekday sleep restriction. However, it does not fully restore immune function, and the irregular schedule itself (social jetlag) disrupts circadian rhythms, which has its own negative health effects. Consistent sleep timing 7 days a week is more beneficial than weekend catch-up.',
  },
];

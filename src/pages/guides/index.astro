---
import ToolLayout from '../../layouts/ToolLayout.astro';
const SITE = 'https://healthcalculation.com';
const canonical = `${SITE}/guides`;

const guides = [
  {
    href: '/guides/how-much-protein-per-day',
    icon: '&#129372;',
    title: 'How Much Protein Do I Need Per Day?',
    desc: 'Evidence-based protein recommendations for adults — by weight, activity level, and goal. Includes a quick-reference table and top food sources.',
    tool: 'Protein Calculator',
    toolHref: '/protein-calculator',
  },
  {
    href: '/guides/healthy-bmi-for-women',
    icon: '&#9878;',
    title: 'What Is a Healthy BMI for Women?',
    desc: 'WHO BMI ranges for women by age group, body fat context, waist circumference thresholds, and when BMI is not a reliable measure.',
    tool: 'BMI Calculator',
    toolHref: '/bmi-calculator',
  },
  {
    href: '/guides/how-to-calculate-tdee',
    icon: '&#128293;',
    title: 'How to Calculate Your TDEE Accurately',
    desc: 'Step-by-step guide to TDEE using the Mifflin-St Jeor formula — activity multipliers, calorie targets by goal, and the 4 most common mistakes.',
    tool: 'Calorie & TDEE Calculator',
    toolHref: '/calorie-tdee-calculator',
  },
  {
    href: '/guides/how-many-calories-does-walking-burn',
    icon: '&#128694;',
    title: 'How Many Calories Does Walking Burn?',
    desc: 'Calorie tables by weight, speed, and duration. Includes the MET formula, incline effects, and 5 tips to burn more on every walk.',
    tool: 'Calories Burned Calculator',
    toolHref: '/calories-burned-calculator',
  },
  {
    href: '/guides/healthy-body-fat-percentage',
    icon: '&#128198;',
    title: 'What Is a Healthy Body Fat Percentage?',
    desc: 'ACE and ACSM body fat ranges for men and women by age, essential vs storage fat, health risk thresholds, and how measurement methods compare.',
    tool: 'Body Fat % Calculator',
    toolHref: '/body-fat-calculator',
  },
  {
    href: '/guides/how-much-water-should-i-drink',
    icon: '&#128167;',
    title: 'How Much Water Should I Drink Per Day?',
    desc: 'NASEM recommendations by body weight, activity level, and climate. Includes a urine color hydration chart and 5 practical tips.',
    tool: 'Water Intake Calculator',
    toolHref: '/water-intake-calculator',
  },
  {
    href: '/guides/healthy-heart-rate-by-age',
    icon: '&#128147;',
    title: 'What Is a Healthy Heart Rate by Age?',
    desc: 'Normal resting heart rate ranges by age, max HR formulas (Tanaka vs 220−age), 5 training zones, and signs that warrant medical attention.',
    tool: 'Heart Rate Zone Calculator',
    toolHref: '/heart-rate-zone-calculator',
  },
  {
    href: '/guides/what-is-my-ideal-weight',
    icon: '&#9878;',
    title: 'What Is My Ideal Weight? 4 Formulas Compared',
    desc: 'Devine, Robinson, Miller, and Hamwi ideal weight formulas compared by height and sex — plus key limitations of IBW targets.',
    tool: 'Ideal Weight Calculator',
    toolHref: '/ideal-weight-calculator',
  },
  {
    href: '/guides/how-to-calculate-macros',
    icon: '&#129367;',
    title: 'How to Calculate Your Macros',
    desc: 'TDEE to gram targets in 4 steps — ratio tables for cutting, bulking, and maintenance, plus the most common macro tracking mistakes.',
    tool: 'Macro Calculator',
    toolHref: '/macro-calculator',
  },
  {
    href: '/guides/how-to-use-one-rep-max',
    icon: '&#127947;',
    title: 'How to Use Your One Rep Max to Build Strength',
    desc: 'Training percentage zones, 4 estimation formulas compared, strength standards by body weight, and how to program 1RM-based periodization.',
    tool: 'One Rep Max Calculator',
    toolHref: '/one-rep-max-calculator',
  },
  {
    href: '/guides/what-is-basal-metabolic-rate',
    icon: '&#128200;',
    title: 'What Is Basal Metabolic Rate (BMR)?',
    desc: 'BMR explained — Mifflin-St Jeor vs Harris-Benedict formulas, normal ranges by age and sex, what affects BMR, and how to use it to set your daily calorie goal.',
    tool: 'BMR Calculator',
    toolHref: '/bmr-calculator',
  },
  {
    href: '/guides/how-to-create-a-calorie-deficit',
    icon: '&#9986;',
    title: 'How to Create a Calorie Deficit for Weight Loss',
    desc: 'Step-by-step deficit calculation — safe deficit sizes, minimum calorie floors, why plateaus happen, and how to adjust when weight loss stalls.',
    tool: 'Calorie Deficit Calculator',
    toolHref: '/calorie-deficit-calculator',
  },
  {
    href: '/guides/how-much-sleep-do-i-need',
    icon: '&#127769;',
    title: 'How Much Sleep Do I Need by Age?',
    desc: 'AASM sleep guidelines by age, the science of 90-minute sleep cycles, signs of chronic sleep deprivation, and evidence-based tips for better sleep.',
    tool: 'Sleep Calculator',
    toolHref: '/sleep-calculator',
  },
  {
    href: '/guides/healthy-waist-to-hip-ratio',
    icon: '&#128200;',
    title: 'What Is a Healthy Waist-to-Hip Ratio?',
    desc: 'WHO thresholds for men and women, WHR vs BMI comparison, how visceral fat drives metabolic risk, and evidence-based strategies to improve your ratio.',
    tool: 'WHR Calculator',
    toolHref: '/waist-to-hip-ratio-calculator',
  },
];
---

<ToolLayout
  title="Health & Fitness Guides — Evidence-Based Articles"
  description="Science-backed guides on protein intake, BMI, TDEE, and more. Each guide links to a free calculator for personalized results."
  canonical={canonical}
  pageIcon="&#128214;"
  heroTitle="Health & Fitness Guides"
>

<div style="max-width:780px;margin:0 auto">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a><span>›</span><span>Guides</span>
  </nav>

  <h1 style="font-size:28px;font-weight:900;margin-bottom:8px">Health &amp; Fitness Guides</h1>
  <p style="font-size:16px;color:var(--mut);margin-bottom:32px">Evidence-based articles paired with free calculators — so you can understand the science and get your personalized number in one place.</p>

  <div class="guides-list">
    {guides.map(g => (
      <a href={g.href} class="guide-card">
        <span class="gc-icon" set:html={g.icon} />
        <div class="gc-body">
          <p class="gc-title">{g.title}</p>
          <p class="gc-desc">{g.desc}</p>
          <p class="gc-tool">Free tool: <span>{g.tool}</span></p>
        </div>
        <span class="gc-arrow">&#8594;</span>
      </a>
    ))}
  </div>
</div>

<style>
  .guides-list { display: flex; flex-direction: column; gap: 16px; }
  .guide-card {
    display: flex; align-items: flex-start; gap: 16px;
    background: #fff; border: 1px solid #e5e7eb; border-radius: 14px;
    padding: 20px; text-decoration: none; color: #1f2937;
    transition: box-shadow .15s, border-color .15s;
  }
  .guide-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); border-color: var(--ac); }
  .gc-icon  { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
  .gc-body  { flex: 1; }
  .gc-title { font-size: 17px; font-weight: 800; margin-bottom: 4px; color: #111827; }
  .gc-desc  { font-size: 14px; color: #6b7280; line-height: 1.55; margin-bottom: 8px; }
  .gc-tool  { font-size: 12px; color: var(--mut); }
  .gc-tool span { color: var(--ac); font-weight: 600; }
  .gc-arrow { color: var(--ac); font-size: 18px; font-weight: 700; flex-shrink: 0; align-self: center; }
</style>

</ToolLayout>

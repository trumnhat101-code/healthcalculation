const SITE = 'https://healthcalculation.com';
const canonical = `${SITE}/guides/healthy-heart-rate-by-age`;

const schemaArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'What Is a Healthy Heart Rate by Age?',
  description: 'Normal resting heart rate ranges by age, target heart rate zones for exercise, and what high or low heart rate means for your health.',
  url: canonical,
  datePublished: '2025-06-01',
  dateModified: '2025-06-18',
  author: { '@type': 'Organization', name: 'HealthCalculation.com' },
  publisher: { '@type': 'Organization', name: 'HealthCalculation.com', url: SITE },
};

const schemaFaq = [
  {
    q: 'What is a normal resting heart rate for adults?',
    a: 'A normal resting heart rate for adults is 60–100 beats per minute (bpm), according to the American Heart Association. Athletes and highly fit individuals often have resting heart rates of 40–60 bpm due to increased cardiac efficiency. Consistently above 100 bpm (tachycardia) or below 60 bpm (bradycardia) in non-athletes warrants medical evaluation.',
  },
  {
    q: 'How do I calculate my maximum heart rate?',
    a: 'The most widely used formula is the Tanaka formula: Max HR = 208 − (0.7 × age). This is more accurate than the older "220 minus age" formula, particularly for older adults. For example, a 40-year-old has an estimated max HR of 208 − (0.7 × 40) = 180 bpm. Your actual max HR can be measured during a graded exercise test.',
  },
  {
    q: 'What heart rate zone should I train in to burn fat?',
    a: 'The fat-burning zone is typically Zone 2: 60–70% of your maximum heart rate. At this intensity, your body relies primarily on fat oxidation for fuel. For a 35-year-old with a max HR of ~184 bpm, Zone 2 is approximately 110–129 bpm. However, total calorie burn (not fat percentage) determines weight loss — higher intensity zones burn more total calories even if the fat percentage is lower.',
  },
  {
    q: 'Is a resting heart rate of 50 bpm normal?',
    a: 'Yes, in most cases. A resting heart rate of 50 bpm is common in physically fit adults and endurance athletes. Regular aerobic exercise strengthens the heart muscle, allowing it to pump more blood per beat (higher stroke volume), which means it needs fewer beats per minute at rest. This is generally a positive sign of cardiovascular fitness.',
  },
  {
    q: 'What causes a high resting heart rate?',
    a: 'Common causes of an elevated resting heart rate (above 100 bpm) include dehydration, stress or anxiety, caffeine or stimulant use, fever or infection, anemia, thyroid disorders, poor cardiovascular fitness, and certain medications. Persistent tachycardia not explained by lifestyle factors should be evaluated by a physician.',
  },
];

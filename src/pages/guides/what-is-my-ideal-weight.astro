const schemaArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'What Is My Ideal Weight? 4 Formulas Compared',
  description: 'The four most widely used ideal weight formulas — Devine, Robinson, Miller, and Hamwi — compared by height and sex, with limitations and practical guidance.',
  url: canonical,
  datePublished: '2025-06-01',
  dateModified: '2025-06-18',
  author: { '@type': 'Organization', name: 'HealthCalculation.com' },
  publisher: { '@type': 'Organization', name: 'HealthCalculation.com', url: SITE },
};

const schemaFaq = [
  {
    q: 'What is the most accurate ideal weight formula?',
    a: 'No single formula is universally accurate because "ideal weight" depends on body composition, bone density, muscle mass, age, and sex — factors these formulas do not measure. The Devine formula (1974) is the most widely used clinically, particularly for medication dosing. Robinson (1983) and Miller (1983) were developed to refine Devine. For practical health purposes, a body fat percentage measurement is more meaningful than any weight-based formula.',
  },
  {
    q: 'How is ideal body weight calculated?',
    a: 'The four main formulas all use height as the primary input, with a sex adjustment. The Devine formula for men is: IBW = 50 kg + 2.3 kg per inch over 5 feet. For women: IBW = 45.5 kg + 2.3 kg per inch over 5 feet. Robinson adjusts the per-inch increment slightly, Miller reduces it further, and Hamwi uses a different base weight. All produce slightly different results for the same individual.',
  },
  {
    q: 'Is ideal body weight the same as a healthy weight?',
    a: 'Not necessarily. Ideal body weight (IBW) formulas were originally developed for clinical applications like drug dosing — not as fitness or aesthetic targets. A "healthy weight" is better defined by the WHO BMI range (18.5–24.9), waist circumference, and body fat percentage. Muscular athletes may exceed IBW while being metabolically healthy. Thin individuals may be within IBW but have unhealthy body fat levels.',
  },
  {
    q: 'What is the Devine formula for ideal body weight?',
    a: 'The Devine formula (1974): For men: IBW = 50 kg + 2.3 kg × (height in inches − 60). For women: IBW = 45.5 kg + 2.3 kg × (height in inches − 60). For example, a 5'10" man has IBW = 50 + 2.3 × 10 = 73 kg (161 lb). This formula is widely used in medicine for calculating drug doses in obese patients.',
  },
  {
    q: 'Do ideal weight formulas account for age?',
    a: 'No — standard IBW formulas (Devine, Robinson, Miller, Hamwi) do not adjust for age. However, research shows that slightly higher BMI values (up to 27) are associated with lower mortality in adults over 65. Older adults typically lose muscle mass (sarcopenia) and may appear light on the scale while carrying excess fat. For this reason, IBW formulas are less clinically useful for elderly populations.',
  },
];

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { LIFTS, type Lift } from '../../data/lifts';

const SITE = 'https://healthcalculation.com';

export function getStaticPaths() {
  return LIFTS.map((l) => ({ params: { lift: l.slug }, props: { l } }));
}

const { l } = Astro.props as { l: Lift };
const canonical = `${SITE}/strength/${l.slug}`;

// Build-time rep → %1RM reference chart (indexable, Epley-consistent)
const REP_CHART = [
  { reps: 1, pct: 100, zone: 'Max strength' },
  { reps: 2, pct: 94, zone: 'Max strength' },
  { reps: 3, pct: 91, zone: 'Max strength' },
  { reps: 4, pct: 88, zone: 'Strength' },
  { reps: 5, pct: 86, zone: 'Strength' },
  { reps: 6, pct: 83, zone: 'Strength' },
  { reps: 8, pct: 79, zone: 'Strength–Hypertrophy' },
  { reps: 10, pct: 75, zone: 'Hypertrophy' },
  { reps: 12, pct: 71, zone: 'Hypertrophy' },
  { reps: 15, pct: 67, zone: 'Endurance' },
];

const schemaApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${l.name} Calculator`,
  url: canonical,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: `Estimate your ${l.phrase} one-rep max (1RM) and get a training percentage chart.`,
};

const others = LIFTS.filter((x) => x.slug !== l.slug).slice(0, 6);
---

<ToolLayout
  title={`${l.name} Calculator — 1RM, Max & Percentage Chart`}
  description={`Calculate your ${l.phrase} one-rep max (1RM) from your reps, plus a full training percentage chart. Free ${l.phrase} calculator.`}
  canonical={canonical}
  schemaApp={schemaApp}
  schemaFaq={l.faq}
  pageIcon={l.icon}
  heroTitle={`${l.name} Calculator`}
>
  <div class="page-layout">
    <div class="main-col">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span aria-hidden="true">›</span>
        <a href="/one-rep-max-calculator">1RM Calculator</a><span aria-hidden="true">›</span>
        <span>{l.name}</span>
      </nav>

      <h1>{l.name} Calculator</h1>
      <p class="lead">{l.intro}</p>

      <!-- ── Calculator ── -->
      <div class="card" id="calc">
        <div class="field-group" style="margin-bottom:14px">
          <span class="field-label">Units</span>
          <div class="seg-group" role="radiogroup" aria-label="Units">
            <label class="seg-opt"><input type="radio" name="unit" value="lbs" checked /><span>Pounds (lbs)</span></label>
            <label class="seg-opt"><input type="radio" name="unit" value="kg" /><span>Kilograms (kg)</span></label>
          </div>
        </div>
        <div class="grid-2">
          <div class="field-group">
            <label class="field-label" for="w">Weight lifted</label>
            <input type="number" id="w" value="185" min="1" max="2000" step="0.5" />
          </div>
          <div class="field-group">
            <label class="field-label" for="r">Reps completed</label>
            <input type="number" id="r" value="5" min="1" max="20" step="1" />
          </div>
        </div>
        <button type="button" id="go" class="btn-calc">Calculate 1RM →</button>

        <div id="out" hidden>
          <div class="orm-big">Estimated 1RM: <span id="orm">—</span> <span id="ou">lbs</span></div>
          <table class="result-table" style="margin-top:14px">
            <thead><tr><th>% of 1RM</th><th>Weight</th><th>Reps</th><th>Training zone</th></tr></thead>
            <tbody id="pctbody"></tbody>
          </table>
        </div>
      </div>

      <AdSlot label="In-content ad" />

      <!-- ── Static reference chart (SEO) ── -->
      <h2>{l.name} Rep Max Percentage Chart</h2>
      <p>Use this chart to convert any rep set into a percentage of your {l.phrase} one-rep max — the basis of percentage-based training.</p>
      <table class="result-table">
        <thead><tr><th>Reps</th><th>% of 1RM</th><th>Training zone</th></tr></thead>
        <tbody>
          {REP_CHART.map((row) => (
            <tr>
              <td><strong>{row.reps}</strong></td>
              <td>{row.pct}%</td>
              <td>{row.zone}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p style="font-size:13px;color:#6b7280;margin-top:8px">Example: if your {l.phrase} 1RM is 200 lbs, a set of 5 (≈86%) would be about 172 lbs.</p>

      <!-- ── How it's calculated ── -->
      <h2>How Your 1RM Is Estimated</h2>
      <p>This calculator averages three validated formulas for accuracy:</p>
      <div class="formula-box">
        Epley: 1RM = w × (1 + reps / 30)<br>
        Brzycki: 1RM = w / (1.0278 − 0.0278 × reps)<br>
        Lander: 1RM = (100 × w) / (101.3 − 2.67 × reps)
      </div>
      <p>Estimates are most accurate with <strong>2–10 rep</strong> sets. Above 10 reps, muscular endurance skews the result, so heavier low-rep sets give a more reliable {l.phrase} 1RM.</p>

      <!-- ── FAQ ── -->
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {l.faq.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <div class="faq-body">{a}</div>
          </details>
        ))}
      </div>

      <!-- ── Cross-links to muscle-building tools ── -->
      <h2>Build Strength & Muscle</h2>
      <p>Progress on the {l.phrase} comes from progressive overload plus enough fuel and protein. Pair this with:</p>
      <div class="related-grid">
        <a href="/protein-calculator" class="related-link">🥩 Protein Calculator</a>
        <a href="/macro-calculator" class="related-link">🥗 Macro Calculator</a>
        <a href="/calorie-tdee-calculator" class="related-link">🔥 Calorie & TDEE Calculator</a>
        <a href="/one-rep-max-calculator" class="related-link">🏋️ Full 1RM Calculator</a>
      </div>

      <!-- ── Sibling lifts ── -->
      <h2>Other Lift Calculators</h2>
      <div class="related-grid">
        {others.map((o) => (
          <a href={`/strength/${o.slug}`} class="related-link">{o.icon} {o.name}</a>
        ))}
      </div>
    </div><!-- /main-col -->

    <aside class="sidebar">
      <AdSlot label="Sidebar ad" format="rectangle" />
      <div class="card" style="font-size:13px;color:#374151">
        <p style="font-weight:700;margin-bottom:8px">Quick reference</p>
        <p>5 reps ≈ <strong>86%</strong> of 1RM</p>
        <p>8 reps ≈ <strong>79%</strong> of 1RM</p>
        <p style="margin-bottom:0">10 reps ≈ <strong>75%</strong> of 1RM</p>
      </div>
    </aside>
  </div>
</ToolLayout>

<script>
  const PCT = [
    { pct: 100, reps: '1', zone: 'Absolute strength' },
    { pct: 95, reps: '2', zone: 'Max strength' },
    { pct: 90, reps: '3–4', zone: 'Max strength' },
    { pct: 85, reps: '5–6', zone: 'Strength' },
    { pct: 80, reps: '7–8', zone: 'Strength–Hypertrophy' },
    { pct: 75, reps: '9–10', zone: 'Hypertrophy' },
    { pct: 70, reps: '11–12', zone: 'Hypertrophy' },
    { pct: 65, reps: '13–15', zone: 'Endurance' },
    { pct: 60, reps: '16–20', zone: 'Endurance' },
  ];

  const w = document.getElementById('w') as HTMLInputElement;
  const r = document.getElementById('r') as HTMLInputElement;
  const out = document.getElementById('out') as HTMLDivElement;

  function unit() {
    return (document.querySelector('input[name="unit"]:checked') as HTMLInputElement).value;
  }

  document.getElementById('go')?.addEventListener('click', () => {
    const weight = parseFloat(w.value);
    const reps = parseFloat(r.value);
    if (!weight || !reps || weight <= 0 || reps < 1) return;

    const epley = reps === 1 ? weight : weight * (1 + reps / 30);
    const brzycki = reps === 1 ? weight : weight / (1.0278 - 0.0278 * reps);
    const lander = reps === 1 ? weight : (100 * weight) / (101.3 - 2.67123 * reps);
    const orm = Math.round((epley + brzycki + lander) / 3);
    const u = unit();

    (document.getElementById('orm') as HTMLElement).textContent = String(orm);
    (document.getElementById('ou') as HTMLElement).textContent = u;

    const body = document.getElementById('pctbody') as HTMLElement;
    body.innerHTML = '';
    for (const row of PCT) {
      const wt = Math.round((orm * row.pct) / 100);
      const tr = document.createElement('tr');
      tr.innerHTML = `<td>${row.pct}%</td><td><strong>${wt} ${u}</strong></td><td>${row.reps}</td><td>${row.zone}</td>`;
      body.appendChild(tr);
    }
    out.hidden = false;
    out.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>

<style>
  .orm-big { margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--bd); font-size: 22px; font-weight: 800; color: var(--tx); }
  .orm-big #orm { color: var(--ac); }
</style>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import Disclaimer from '../components/Disclaimer.astro';

const SITE = 'https://healthcalculation.com';

const faq = [
  {
    q: 'What is TDEE and why does it matter?',
    a: 'Total Daily Energy Expenditure (TDEE) is the total number of calories your body burns in a day, including your resting metabolism, physical activity, and the energy used to digest food. It is the single most important number for managing your weight — eating below it causes weight loss, eating above it causes weight gain.',
  },
  {
    q: 'How many calories should I eat to lose 1 pound per week?',
    a: 'One pound of fat contains approximately 3,500 calories. To lose 1 lb per week, you need a daily deficit of ~500 calories below your TDEE. This calculator shows that number directly as the "Weight Loss" target. Deficits larger than 1,000 kcal/day are not recommended as they risk muscle loss and nutritional deficiencies.',
  },
  {
    q: 'How accurate is the Mifflin-St Jeor formula?',
    a: 'Studies show Mifflin-St Jeor predicts BMR within 10% for most people. It outperforms the older Harris-Benedict formula in accuracy. However, no formula accounts for individual metabolic variation, medical conditions, or body composition — treat your result as a starting point and adjust based on real-world results over 2–3 weeks.',
  },
  {
    q: 'Should I eat back the calories I burn exercising?',
    a: 'Not necessarily. The activity multipliers in TDEE calculations already account for your exercise level. If you selected the correct activity level, your exercise calories are already included. Only eat back exercise calories if you chose a lower activity level or if your workout was unusually intense.',
  },
  {
    q: 'What is the difference between BMR and TDEE?',
    a: 'BMR (Basal Metabolic Rate) is the calories your body needs at complete rest — just to keep organs functioning. TDEE includes all activity on top of BMR. For most people, TDEE is 1.4–1.9× their BMR. Eating at BMR is not recommended as it is too restrictive for most people to sustain.',
  },
];

const affiliates = [
  {
    href: '#AFFILIATE-NOOM',        // TODO: replace with real affiliate link
    label: 'Noom',
    sub: 'Psychology-based weight loss program · Personalized coaching',
    badge: 'Top Pick',
  },
  {
    href: '#AFFILIATE-HELLOFRESH',
    label: 'HelloFresh',
    sub: 'Pre-portioned meal kits · Easy calorie tracking',
  },
  {
    href: '#AFFILIATE-FACTOR',
    label: 'Factor Meals',
    sub: 'Ready-to-eat healthy meals · Chef-crafted, dietitian-approved',
  },
];

const related = [
  { href: '/bmi-calculator',    label: 'BMI Calculator',    desc: 'Check your Body Mass Index' },
  { href: '/macro-calculator',  label: 'Macro Calculator',  desc: 'Find your protein, carbs & fat targets' },
  { href: '/sleep-calculator',  label: 'Sleep Calculator',  desc: 'Optimize your sleep cycles' },
];

const schemaApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Calorie & TDEE Calculator',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  url: `${SITE}/calorie-tdee-calculator`,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Free online calorie and TDEE calculator using the Mifflin-St Jeor formula.',
};
---

<ToolLayout
  title="Calorie Calculator — Daily Calories & TDEE (Free, Accurate)"
  description="Calculate your daily calorie needs and TDEE in seconds using the Mifflin-St Jeor formula. Find your BMR and set goals to lose, maintain, or gain weight."
  canonical={`${SITE}/calorie-tdee-calculator`}
  schemaApp={schemaApp}
  schemaFaq={faq}
>

  <div class="page-layout">
    <!-- ── Main column ── -->
    <div class="main-col">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>Calorie Calculator</span>
      </nav>

      <h1>Calorie Calculator</h1>
      <p class="lead">
        Find your BMR and Total Daily Energy Expenditure (TDEE) to set realistic
        weight-loss or muscle-gain targets. Uses the clinically validated
        <strong>Mifflin-St Jeor formula</strong>.
      </p>

      <!-- ── Tool card ── -->
      <div class="card" id="calculator">
        <form id="calForm" novalidate>

          <!-- Units toggle -->
          <div class="field-group" style="margin-bottom:18px">
            <label class="field-label">Units</label>
            <div class="seg-group" role="radiogroup" aria-label="Unit system">
              <label class="seg-opt">
                <input type="radio" name="units" value="us" checked />
                <span>US (lbs, ft/in)</span>
              </label>
              <label class="seg-opt">
                <input type="radio" name="units" value="metric" />
                <span>Metric (kg, cm)</span>
              </label>
            </div>
          </div>

          <!-- Sex -->
          <div class="field-group" style="margin-bottom:18px">
            <label class="field-label">Biological Sex</label>
            <div class="seg-group" role="radiogroup" aria-label="Biological sex">
              <label class="seg-opt">
                <input type="radio" name="sex" value="m" checked />
                <span>Male</span>
              </label>
              <label class="seg-opt">
                <input type="radio" name="sex" value="f" />
                <span>Female</span>
              </label>
            </div>
          </div>

          <!-- Age / Weight / Height -->
          <div class="grid-3">
            <div class="field-group">
              <label class="field-label" for="age">Age</label>
              <input type="number" id="age" name="age" min="15" max="100" placeholder="30" required />
            </div>
            <div class="field-group">
              <label class="field-label" for="weight">Weight</label>
              <input type="number" id="weight" name="weight" min="1" placeholder="165" required />
              <span class="field-unit" id="weightUnit">lbs</span>
            </div>
            <div class="field-group">
              <label class="field-label" for="heightCm" id="heightLabel">Height</label>
              <!-- metric -->
              <input type="number" id="heightCm" name="heightCm" min="100" max="250" placeholder="175" class="hide-metric" />
              <!-- US: ft + in -->
              <div class="ft-in show-us" id="ftInGroup">
                <input type="number" id="heightFt" name="heightFt" min="3" max="8" placeholder="5" aria-label="Feet" />
                <span class="field-sep">ft</span>
                <input type="number" id="heightIn" name="heightIn" min="0" max="11" placeholder="9" aria-label="Inches" />
                <span class="field-sep">in</span>
              </div>
            </div>
          </div>

          <!-- Activity -->
          <div class="field-group" style="margin-top:14px">
            <label class="field-label" for="activity">Activity Level</label>
            <select id="activity" name="activity">
              <option value="1.2">Sedentary (desk job, little/no exercise)</option>
              <option value="1.375">Lightly active (light exercise 1–3 days/wk)</option>
              <option value="1.55" selected>Moderately active (moderate exercise 3–5 days/wk)</option>
              <option value="1.725">Very active (hard exercise 6–7 days/wk)</option>
              <option value="1.9">Extra active (physical job or 2× training/day)</option>
            </select>
          </div>

          <button type="submit" class="btn-calc">Calculate My Calories →</button>
        </form>

        <!-- Results (hidden until calculated) -->
        <div id="results" class="results" hidden>
          <div class="kpi-grid">
            <div class="kpi main">
              <div class="kpi-v" id="resTdee">—</div>
              <div class="kpi-l">TDEE (maintain weight)</div>
            </div>
            <div class="kpi">
              <div class="kpi-v" id="resBmr">—</div>
              <div class="kpi-l">BMR (resting)</div>
            </div>
          </div>
          <div class="goals">
            <div class="goal-row">
              <span>🔥 Lose 1 lb/wk</span>
              <strong id="resLose1">—</strong>
            </div>
            <div class="goal-row">
              <span>🔥🔥 Lose 2 lbs/wk</span>
              <strong id="resLose2">—</strong>
            </div>
            <div class="goal-row">
              <span>⚖️ Maintain weight</span>
              <strong id="resMaint">—</strong>
            </div>
            <div class="goal-row">
              <span>💪 Gain 1 lb/wk</span>
              <strong id="resGain1">—</strong>
            </div>
          </div>
          <Disclaimer short={true} />
        </div>
      </div><!-- /card -->

      <!-- Affiliate CTA — shown after results -->
      <div id="affSection" hidden>
        <AffiliateCTA
          heading="Reach Your Calorie Goals Faster"
          items={affiliates}
        />
      </div>

      <AdSlot label="In-content ad" />

      <!-- ── Explainer content ── -->
      <h2>How to Use This Calorie Calculator</h2>
      <p>
        Enter your age, biological sex, weight, height, and typical activity level, then click
        <em>Calculate</em>. You'll see your <strong>BMR</strong> (how many calories your body
        burns at complete rest) and your <strong>TDEE</strong> — the total you burn each day
        including activity.
      </p>
      <p>
        To <strong>lose weight</strong>, aim for a daily intake 500–1,000 calories below your
        TDEE (equivalent to 1–2 lbs/week). To <strong>gain muscle</strong>, eat 250–500 calories
        above your TDEE paired with resistance training.
      </p>

      <h2>The Mifflin-St Jeor Formula</h2>
      <p>
        This calculator uses the <strong>Mifflin-St Jeor equation</strong>, validated in a
        2005 meta-analysis in the <em>Journal of the American Dietetic Association</em> as the
        most accurate predictive equation for resting metabolic rate in most adults.
      </p>
      <div class="formula-box">
        <p><strong>Men:</strong> BMR = (10 × kg) + (6.25 × cm) − (5 × age) + 5</p>
        <p><strong>Women:</strong> BMR = (10 × kg) + (6.25 × cm) − (5 × age) − 161</p>
        <p style="margin-top:8px;font-size:13px;color:#6b7280">TDEE = BMR × Activity Multiplier (1.2–1.9)</p>
      </div>
      <Disclaimer />

    </div><!-- /main-col -->

    <!-- ── Sidebar ── -->
    <aside class="sidebar">
      <AdSlot label="Sidebar ad" format="rectangle" />
      <div class="card" style="font-size:13px;color:#374151">
        <p style="font-weight:700;margin-bottom:8px">Quick Targets</p>
        <p>Lose 1 lb/wk → <strong>TDEE − 500 cal</strong></p>
        <p>Lose 2 lbs/wk → <strong>TDEE − 1,000 cal</strong></p>
        <p>Maintain → <strong>Eat at TDEE</strong></p>
        <p style="margin-bottom:0">Gain muscle → <strong>TDEE + 300 cal</strong></p>
      </div>
    </aside>
  </div>


<!-- FAQ -->
<!-- Who Should Use -->
<section class="content-section">
  <h2>Who Should Use This Calculator?</h2>
  <p>This calculator is ideal for adults who want to understand their daily energy needs — whether the goal is weight loss, muscle gain, or weight maintenance. It is particularly useful for people starting a new diet, athletes adjusting intake for training cycles, and anyone who has hit a weight-loss plateau and wants to re-calibrate their calorie targets. The TDEE estimate accounts for activity level, making it more actionable than a simple basal metabolic rate (BMR) figure alone.</p>
</section>

<!-- Tips for Accuracy -->
<section class="content-section">
  <h2>Tips for Accurate Results</h2>
  <p>For the most accurate TDEE estimate, be honest about your activity level — most people overestimate how active they are. Use your weight measured first thing in the morning, consistently, over several days and average the results. Re-calculate your TDEE every 10–15 lbs of weight change, as BMR shifts with body weight. Track actual intake with a food diary for at least two weeks before comparing to your calculated TDEE.</p>
</section>

<section class="content-section">
  <h2>Frequently Asked Questions</h2>
  {faq.map(({ q, a }) => (
    <details class="faq-item">
      <summary>{q}</summary>
      <p set:html={a} />
    </details>
  ))}
</section>


<!-- How it works -->
<section class="content-section">
  <h2>How Your Calorie Needs Are Calculated</h2>
  <p>This calculator uses the <strong>Mifflin-St Jeor equation</strong> (1990), the most accurate formula for estimating Basal Metabolic Rate (BMR) in the general population according to the Academy of Nutrition and Dietetics.</p>
  <div class="formula-box">
    BMR (men) = 10 &times; weight(kg) + 6.25 &times; height(cm) &minus; 5 &times; age + 5<br>
    BMR (women) = 10 &times; weight(kg) + 6.25 &times; height(cm) &minus; 5 &times; age &minus; 161<br><br>
    TDEE = BMR &times; Activity Multiplier
  </div>
  <p>Your Total Daily Energy Expenditure (TDEE) is then used to calculate intake targets for different goals: a <strong>500 kcal deficit</strong> targets ~1 lb/week loss, while a <strong>300 kcal surplus</strong> supports lean muscle gain.</p>
</section>


<!-- Related -->
<section class="content-section">
  <h2>Related Calculators</h2>
  <div class="related-grid">
    <a href="/macro-calculator" class="related-link">&#9881; Macro Calculator</a>
    <a href="/bmi-calculator" class="related-link">&#9878; BMI Calculator</a>
    <a href="/ideal-weight-calculator" class="related-link">&#9878; Ideal Weight</a>
    <a href="/body-fat-calculator" class="related-link">&#37; Body Fat %</a>
  </div>
</section>

</ToolLayout>

<script>
// ── Calorie / TDEE Calculator Logic ──

const form    = document.getElementById('calForm') as HTMLFormElement;
const results = document.getElementById('results') as HTMLDivElement;
const affSec  = document.getElementById('affSection') as HTMLDivElement;

// Unit toggle
document.querySelectorAll<HTMLInputElement>('input[name="units"]').forEach(r => {
  r.addEventListener('change', () => {
    const isUS = r.value === 'us';
    (document.getElementById('ftInGroup') as HTMLElement).style.display  = isUS ? 'flex' : 'none';
    (document.getElementById('heightCm')  as HTMLInputElement).style.display = isUS ? 'none' : 'block';
    (document.getElementById('weightUnit') as HTMLElement).textContent   = isUS ? 'lbs' : 'kg';
  });
});

function fmt(n: number): string {
  return Math.round(n).toLocaleString() + ' cal/day';
}

form.addEventListener('submit', (e) => {
  e.preventDefault();
  const fd = new FormData(form);

  const units    = fd.get('units') as string;
  const sex      = fd.get('sex') as string;
  const age      = parseFloat(fd.get('age') as string);
  const activity = parseFloat(fd.get('activity') as string);

  let weightKg: number, heightCm: number;

  if (units === 'us') {
    const lbs = parseFloat(fd.get('weight') as string);
    const ft  = parseFloat(fd.get('heightFt') as string) || 0;
    const inc = parseFloat(fd.get('heightIn') as string) || 0;
    weightKg = lbs * 0.453592;
    heightCm = (ft * 12 + inc) * 2.54;
  } else {
    weightKg = parseFloat(fd.get('weight') as string);
    heightCm = parseFloat(fd.get('heightCm') as string);
  }

  if (!age || !weightKg || !heightCm || isNaN(activity)) return;

  // Mifflin-St Jeor
  const s   = sex === 'm' ? 5 : -161;
  const bmr = 10 * weightKg + 6.25 * heightCm - 5 * age + s;
  const tdee = bmr * activity;

  (document.getElementById('resBmr')   as HTMLElement).textContent = fmt(bmr);
  (document.getElementById('resTdee')  as HTMLElement).textContent = fmt(tdee);
  (document.getElementById('resLose1') as HTMLElement).textContent = fmt(tdee - 500);
  (document.getElementById('resLose2') as HTMLElement).textContent = fmt(tdee - 1000);
  (document.getElementById('resMaint') as HTMLElement).textContent = fmt(tdee);
  (document.getElementById('resGain1') as HTMLElement).textContent = fmt(tdee + 500);

  results.hidden = false;
  affSec.hidden  = false;
  results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>

<style>

  .ft-in {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ft-in input { width: 60px; flex: 1; }
  .hide-metric { display: none; }

  /* Segment radio */
  .seg-group {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .seg-opt {
    flex: 1;
    min-width: 90px;
  }
  .seg-opt span {
    display: block;
    text-align: center;
    padding: 8px 12px;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    font-size: 14px;
    cursor: pointer;
    color: #374151;
    transition: border-color .15s, color .15s, background .15s;
  }
  .seg-opt input:checked + span {
    border-color: #16a34a;
    color: #16a34a;
    background: #f0fdf4;
    font-weight: 700;
  }

  .btn-calc {
    width: 100%;
    margin-top: 18px;
    padding: 13px;
    background: #16a34a;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background .15s;
  }

  /* Results */
  .results { margin-top: 20px; padding-top: 18px; border-top: 1px solid #e5e7eb; }
  .kpi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 14px;
  }
  @media (max-width: 400px) {
    .kpi-grid { grid-template-columns: 1fr; }
  }
  .kpi {
    background: #f6faf7;
    border-radius: 10px;
    padding: 14px 16px;
  }
  .kpi.main { background: #e7f7ec; }
  .kpi-v { font-size: 22px; font-weight: 800; color: #16a34a; }
  .kpi-l { font-size: 12px; color: #6b7280; margin-top: 2px; }
  .goals { border-top: 1px solid #e5e7eb; padding-top: 12px; }
  .goal-row {
    display: flex;
    justify-content: space-between;
    padding: 7px 0;
    font-size: 14px;
    border-bottom: 1px dashed #e5e7eb;
  }
  .goal-row strong { color: #16a34a; }

  /* Formula box */
  .formula-box {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 14px 18px;
    font-family: monospace;
    font-size: 13px;
    color: #374151;
    margin: 12px 0 20px;
    line-height: 1.8;
  }
</style>
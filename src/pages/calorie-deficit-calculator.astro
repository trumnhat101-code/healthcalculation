---
import ToolLayout from '../layouts/ToolLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import AdSlot from '../components/AdSlot.astro';

const SITE = 'https://healthcalculation.com';

const faq = [
  {
    q: 'How many calories should I cut to lose 1 pound per week?',
    a: 'One pound of body fat contains approximately 3,500 calories. To lose 1 lb per week, you need a daily calorie deficit of 500 calories below your TDEE. This calculator computes that target automatically from your inputs.',
  },
  {
    q: 'Is a 1,000 calorie deficit per day safe?',
    a: 'A 1,000 calorie deficit targets roughly 2 lbs of weight loss per week and is considered the upper safe limit for most adults. Deficits larger than 1,000 kcal/day increase the risk of muscle loss, nutritional deficiencies, fatigue, and metabolic adaptation. Consult a healthcare provider before pursuing aggressive deficits.',
  },
  {
    q: 'What happens if I eat below my BMR?',
    a: 'Eating at or below your BMR — with no allowance for activity — is too restrictive for sustained fat loss. The body responds with increased hunger, metabolic slowdown (adaptive thermogenesis), muscle catabolism, and hormonal disruption. Most people should not go below 1,200 calories/day (women) or 1,500 calories/day (men) without medical supervision.',
  },
  {
    q: 'Why did my weight loss stall after a few weeks?',
    a: 'As you lose weight, your BMR decreases because a lighter body burns fewer calories. The calorie deficit that worked at the start becomes smaller over time. Recalculate your TDEE and deficit every 10–15 lbs of weight lost to keep pace with your changing body.',
  },
  {
    q: 'Should I use net calories or gross calories?',
    a: 'This calculator uses gross calories — the total you should eat per day, already accounting for your activity level in the TDEE estimate. You do not need to add back exercise calories separately, as long as you selected the correct activity level.',
  },
];

const schemaApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Calorie Deficit Calculator",
  applicationCategory: "HealthApplication",
  operatingSystem: "Web",
  url: `${SITE}/calorie-deficit-calculator`,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description: "Free calorie deficit calculator for weight loss. Find your daily calorie target to lose 0.5, 1, or 2 lbs per week.",
};
---

<ToolLayout
  title="Calorie Deficit Calculator — How Many Calories to Lose Weight"
  description="Calculate your calorie deficit for weight loss. Enter your stats to find your TDEE and exact daily calorie targets for losing 0.5, 1, or 2 pounds per week."
  canonical={`${SITE}/calorie-deficit-calculator`}
  schemaApp={schemaApp}
  schemaFaq={faq}
>

  <div class="page-layout">
    <div class="main-col">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">&#8250;</span>
        <span>Calorie Deficit Calculator</span>
      </nav>

      <h1>Calorie Deficit Calculator</h1>
      <p class="lead">
        Find exactly how many calories to eat each day to reach your weight loss goal.
        Enter your stats below — the calculator estimates your <strong>TDEE</strong> using the
        Mifflin-St Jeor formula and shows calorie targets for three deficit levels.
      </p>

      <!-- Tool card -->
      <div class="card" id="calculator">
        <form id="defForm" novalidate>

          <!-- Units -->
          <div class="field-group" style="margin-bottom:18px">
            <label class="field-label">Units</label>
            <div class="seg-group" role="radiogroup" aria-label="Unit system">
              <label class="seg-opt">
                <input type="radio" name="units" value="us" checked />
                <span>US (lbs, ft/in)</span>
              </label>
              <label class="seg-opt">
                <input type="radio" name="units" value="metric" />
                <span>Metric (kg, cm)</span>
              </label>
            </div>
          </div>

          <!-- Sex -->
          <div class="field-group" style="margin-bottom:18px">
            <label class="field-label">Biological Sex</label>
            <div class="seg-group" role="radiogroup" aria-label="Biological sex">
              <label class="seg-opt">
                <input type="radio" name="sex" value="m" checked />
                <span>Male</span>
              </label>
              <label class="seg-opt">
                <input type="radio" name="sex" value="f" />
                <span>Female</span>
              </label>
            </div>
          </div>

          <!-- Age / Weight / Height -->
          <div class="grid-3">
            <div class="field-group">
              <label class="field-label" for="age">Age</label>
              <input type="number" id="age" name="age" min="15" max="100" placeholder="30" required />
            </div>
            <div class="field-group">
              <label class="field-label" for="weight">Weight</label>
              <input type="number" id="weight" name="weight" min="1" placeholder="165" required />
              <span class="field-unit" id="weightUnit">lbs</span>
            </div>
            <div class="field-group">
              <label class="field-label">Height</label>
              <input type="number" id="heightCm" name="heightCm" min="100" max="250" placeholder="175" style="display:none" />
              <div class="ft-in" id="ftInGroup">
                <input type="number" id="heightFt" name="heightFt" min="3" max="8" placeholder="5" aria-label="Feet" />
                <span class="field-sep">ft</span>
                <input type="number" id="heightIn" name="heightIn" min="0" max="11" placeholder="9" aria-label="Inches" />
                <span class="field-sep">in</span>
              </div>
            </div>
          </div>

          <!-- Activity -->
          <div class="field-group" style="margin-top:14px">
            <label class="field-label" for="activity">Activity Level</label>
            <select id="activity" name="activity">
              <option value="1.2">Sedentary (desk job, little/no exercise)</option>
              <option value="1.375">Lightly active (light exercise 1-3 days/wk)</option>
              <option value="1.55" selected>Moderately active (moderate exercise 3-5 days/wk)</option>
              <option value="1.725">Very active (hard exercise 6-7 days/wk)</option>
              <option value="1.9">Extra active (physical job or 2x training/day)</option>
            </select>
          </div>

          <!-- Goal weight (optional) -->
          <div class="field-group" style="margin-top:14px">
            <label class="field-label" for="goalWeight">Goal Weight <span style="font-weight:400;color:#9ca3af">(optional)</span></label>
            <input type="number" id="goalWeight" name="goalWeight" min="1" placeholder="Leave blank to skip" />
            <span class="field-unit" id="goalWeightUnit">lbs</span>
          </div>

          <button type="submit" class="btn-calc">Calculate My Deficit &#8594;</button>
        </form>

        <!-- Results -->
        <div id="results" class="results" hidden>

          <!-- TDEE + deficit targets -->
          <div class="kpi-grid-3">
            <div class="kpi">
              <div class="kpi-v" id="resTdee">—</div>
              <div class="kpi-l">TDEE (maintain)</div>
            </div>
            <div class="kpi">
              <div class="kpi-v" id="resBmr">—</div>
              <div class="kpi-l">BMR (at rest)</div>
            </div>
          </div>

          <p style="font-size:13px;font-weight:700;margin:18px 0 8px">Daily calorie targets by loss rate:</p>
          <table class="def-table">
            <thead>
              <tr><th>Goal</th><th>Cal/day</th><th>Deficit</th><th>Time to goal*</th></tr>
            </thead>
            <tbody id="defBody"></tbody>
          </table>
          <p style="font-size:11px;color:#9ca3af;margin-top:6px">* Time to goal shown only when goal weight is entered and deficit is safe (&ge;1,200 cal/day for women, &ge;1,500 cal/day for men).</p>

          <Disclaimer short={true} />
        </div>
      </div><!-- /card -->

      <AdSlot label="In-content ad" />

      <h2>What Is a Calorie Deficit?</h2>
      <p>
        A calorie deficit occurs when you consume fewer calories than your body burns in a day.
        Your body responds by drawing on stored energy — primarily body fat — to make up the
        shortfall. One pound of body fat holds approximately 3,500 calories, so a consistent
        daily deficit of 500 calories produces roughly 1 lb of fat loss per week.
      </p>
      <p>
        This calculator estimates your <strong>TDEE</strong> (Total Daily Energy Expenditure)
        using the Mifflin-St Jeor formula, then calculates the exact intake targets for three
        common deficit levels: 0.5 lb, 1 lb, and 2 lbs per week.
      </p>

      <h2>Choosing the Right Deficit Size</h2>
      <div class="formula-box">
        <p><strong>Mild deficit (250 cal/day) → 0.5 lb/week</strong></p>
        <p>Best for athletes preserving muscle, or those close to goal weight. Slower but more sustainable.</p>
        <p style="margin-top:10px"><strong>Moderate deficit (500 cal/day) → 1 lb/week</strong></p>
        <p>The gold standard for most people. Balances meaningful progress with sustainability.</p>
        <p style="margin-top:10px"><strong>Aggressive deficit (1,000 cal/day) → 2 lbs/week</strong></p>
        <p>Upper safe limit for most adults. Requires careful nutrition to prevent muscle loss. Not recommended below 1,200 cal/day (women) or 1,500 cal/day (men).</p>
      </div>
      <Disclaimer />

    </div><!-- /main-col -->

    <!-- Sidebar -->
    <aside class="sidebar">
      <AdSlot label="Sidebar ad" format="rectangle" />
      <div class="card" style="font-size:13px;color:#374151">
        <p style="font-weight:700;margin-bottom:10px">&#9986; Deficit Quick Reference</p>
        <p>250 cal deficit = 0.5 lb/week</p>
        <p>500 cal deficit = 1 lb/week</p>
        <p>750 cal deficit = 1.5 lbs/week</p>
        <p>1,000 cal deficit = 2 lbs/week</p>
        <p style="margin-top:8px;padding-top:8px;border-top:1px solid #e5e7eb;color:#ef4444;font-weight:600">Min safe: 1,200 (W) / 1,500 (M)</p>
        <p style="margin-bottom:0">Recalculate every 10-15 lbs lost</p>
      </div>
    </aside>
  </div>


<section class="content-section">
  <h2>Why Your Deficit Should Be Based on TDEE, Not BMR</h2>
  <p>
    A common mistake is cutting calories relative to BMR (resting calories only). BMR does not include
    any activity — even light walking or daily chores. Eating at your BMR puts you in a far larger
    deficit than intended, accelerating muscle loss and causing rapid metabolic adaptation. Always
    base your deficit on <strong>TDEE</strong>, which accounts for your real-world activity level.
  </p>
</section>

<section class="content-section">
  <h2>How to Track Your Progress</h2>
  <p>
    The most reliable way to verify your deficit is working is to track your weight at the same
    time each morning over two weeks and average the readings. A true 500-calorie daily deficit
    should yield roughly 0.5–1.2 lbs of scale weight drop per week (some variation is normal due
    to water retention and glycogen shifts). If you are losing significantly faster or slower
    after two weeks, adjust your intake by 100–150 calories and monitor for another two weeks
    before making further changes.
  </p>
</section>

<section class="content-section">
  <h2>Frequently Asked Questions</h2>
  {faq.map(({ q, a }) => (
    <details class="faq-item">
      <summary>{q}</summary>
      <p set:html={a} />
    </details>
  ))}
</section>

<!-- Guide CTA -->
<section class="content-section">
  <div class="guide-cta-box">
    <div class="gcta-icon">&#128293;</div>
    <div class="gcta-body">
      <div class="gcta-label">From Our Guides</div>
      <a href="/guides/how-to-create-a-calorie-deficit" class="gcta-title">How to Create a Calorie Deficit for Weight Loss</a>
      <p class="gcta-desc">Deficit sizes explained, minimum calorie floors, why plateaus happen, and a step-by-step method to keep fat loss progressing over time.</p>
    </div>
    <a href="/guides/how-to-create-a-calorie-deficit" class="gcta-btn">Read guide &rarr;</a>
  </div>
  <div class="related-grid" style="margin-top:16px">
    <a href="/guides/how-many-calories-to-lose-10-pounds" class="related-link">&#127919; How Many Calories to Lose 10 Pounds</a>
    <a href="/guides/how-to-calculate-tdee" class="related-link">&#128293; How to Calculate Your TDEE</a>
  </div>
</section>

<!-- Related -->
<section class="content-section">
  <h2>Related Calculators</h2>
  <div class="related-grid">
    <a href="/bmr-calculator"           class="related-link">&#128200; BMR Calculator</a>
    <a href="/calorie-tdee-calculator"  class="related-link">&#128293; Calorie &amp; TDEE</a>
    <a href="/macro-calculator"         class="related-link">&#129367; Macro Calculator</a>
    <a href="/body-fat-calculator"      class="related-link">&#128198; Body Fat %</a>
  </div>
</section>

</ToolLayout>

<script>
const form    = document.getElementById('defForm') as HTMLFormElement;
const results = document.getElementById('results') as HTMLDivElement;

// Unit toggle
document.querySelectorAll<HTMLInputElement>('input[name="units"]').forEach(r => {
  r.addEventListener('change', () => {
    const isUS = r.value === 'us';
    (document.getElementById('ftInGroup')   as HTMLElement).style.display    = isUS ? 'flex'  : 'none';
    (document.getElementById('heightCm')    as HTMLInputElement).style.display = isUS ? 'none'  : 'block';
    (document.getElementById('weightUnit')  as HTMLElement).textContent      = isUS ? 'lbs'   : 'kg';
    (document.getElementById('goalWeightUnit') as HTMLElement).textContent   = isUS ? 'lbs'   : 'kg';
  });
});

const GOALS = [
  { label: 'Lose 0.5 lb/week', deficit: 250  },
  { label: 'Lose 1 lb/week',   deficit: 500  },
  { label: 'Lose 2 lbs/week',  deficit: 1000 },
];

function fmt(n: number): string {
  return Math.round(n).toLocaleString() + ' cal/day';
}

form.addEventListener('submit', (e) => {
  e.preventDefault();
  const fd = new FormData(form);

  const units    = fd.get('units')    as string;
  const sex      = fd.get('sex')      as string;
  const age      = parseFloat(fd.get('age') as string);
  const activity = parseFloat(fd.get('activity') as string);
  const goalW    = parseFloat(fd.get('goalWeight') as string);

  let weightKg: number, heightCm: number;

  if (units === 'us') {
    const lbs = parseFloat(fd.get('weight')   as string);
    const ft  = parseFloat(fd.get('heightFt') as string) || 0;
    const inc = parseFloat(fd.get('heightIn') as string) || 0;
    weightKg = lbs * 0.453592;
    heightCm = (ft * 12 + inc) * 2.54;
  } else {
    weightKg = parseFloat(fd.get('weight')   as string);
    heightCm = parseFloat(fd.get('heightCm') as string);
  }

  if (!age || !weightKg || !heightCm || isNaN(activity)) return;

  const s   = sex === 'm' ? 5 : -161;
  const bmr = 10 * weightKg + 6.25 * heightCm - 5 * age + s;
  const tdee = bmr * activity;

  // Goal weight in kg
  let goalKg = NaN;
  if (!isNaN(goalW) && goalW > 0) {
    goalKg = units === 'us' ? goalW * 0.453592 : goalW;
  }
  const lbsToLose = isNaN(goalKg) ? NaN : (weightKg - goalKg) * 2.20462;

  const minCal = sex === 'm' ? 1500 : 1200;

  (document.getElementById('resTdee') as HTMLElement).textContent = fmt(tdee);
  (document.getElementById('resBmr')  as HTMLElement).textContent = fmt(bmr);

  const tbody = document.getElementById('defBody') as HTMLTableSectionElement;
  tbody.innerHTML = '';

  GOALS.forEach(({ label, deficit }) => {
    const target = tdee - deficit;
    const safe   = target >= minCal;
    const weeksStr = (!isNaN(lbsToLose) && lbsToLose > 0 && safe)
      ? Math.ceil(lbsToLose / (deficit / 3500)) + ' wks'
      : '—';
    const tr = document.createElement('tr');
    if (!safe) tr.style.color = '#9ca3af';
    tr.innerHTML = `<td>${label}</td><td>${safe ? fmt(target) : 'Below minimum'}</td><td>&#8722;${deficit.toLocaleString()} cal</td><td>${weeksStr}</td>`;
    tbody.appendChild(tr);
  });

  results.hidden = false;
  results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>

<style>
  .ft-in { display: flex; align-items: center; gap: 6px; }
  .ft-in input { width: 60px; flex: 1; }

  .seg-group { display: flex; gap: 8px; flex-wrap: wrap; }
  .seg-opt { flex: 1; min-width: 90px; }
  .seg-opt span {
    display: block; text-align: center; padding: 8px 12px;
    border: 1.5px solid #e5e7eb; border-radius: 8px;
    font-size: 14px; cursor: pointer; color: #374151;
    transition: border-color .15s, color .15s, background .15s;
  }
  .seg-opt input:checked + span {
    border-color: #16a34a; color: #16a34a;
    background: #f0fdf4; font-weight: 700;
  }

  .btn-calc {
    width: 100%; margin-top: 18px; padding: 13px;
    background: #16a34a; color: #fff; font-size: 16px; font-weight: 700;
    border: none; border-radius: 10px; cursor: pointer; transition: background .15s;
  }

  .results { margin-top: 20px; padding-top: 18px; border-top: 1px solid #e5e7eb; }

  .kpi-grid-3 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px; }
  @media (max-width: 400px) { .kpi-grid-3 { grid-template-columns: 1fr; } }
  .kpi { background: #f6faf7; border-radius: 10px; padding: 14px 16px; }
  .kpi-v { font-size: 22px; font-weight: 800; color: #1f2937; margin: 0 0 4px; }
  .kpi-l { font-size: 12px; color: #6b7280; }

  .def-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .def-table th { background: #f0fdf4; color: #16a34a; font-weight: 700; padding: 8px 10px; text-align: left; border-bottom: 2px solid #bbf7d0; }
  .def-table td { padding: 8px 10px; border-bottom: 1px solid #e5e7eb; }
  .def-table tr:last-child td { border-bottom: none; }
</style>
